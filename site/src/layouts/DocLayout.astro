---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { buildBreadcrumbList } from '../lib/structured-data';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  lastmod?: string;
}

const { title, description, keywords, lastmod } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://zolotukhin.ai';
const metaDescription = description ?? `${title} — ZINC documentation`;
const breadcrumbItems = [
  { name: 'Home', href: '/' },
  { name: 'ZINC', href: '/zinc' },
  { name: 'Docs', href: '/zinc/docs' },
  { name: title },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      headline: title,
      ...(lastmod ? { dateModified: lastmod } : {}),
      author: {
        '@type': 'Organization',
        name: 'ZINC Project',
      },
      description: metaDescription,
      url: Astro.url.href,
      mainEntityOfPage: Astro.url.href,
    },
    buildBreadcrumbList(siteUrl, breadcrumbItems),
  ],
};

const docNavSections = [
  {
    label: 'Start Here',
    items: [
      { slug: 'getting-started', label: 'Getting Started' },
      { slug: 'hardware-requirements', label: 'Hardware Requirements' },
      { slug: 'running-zinc', label: 'Running ZINC' },
      { slug: 'api', label: 'Serving HTTP API' },
    ],
  },
  {
    label: 'Deep Docs',
    items: [
      { slug: 'spec', label: 'Technical Spec' },
      { slug: 'rdna4-tuning', label: 'RDNA4 Tuning' },
      { slug: 'gpu-reference', label: 'GPU Reference' },
      { slug: 'turboquant-spec', label: 'TurboQuant' },
      { slug: 'zig-api', label: 'Zig API' },
    ],
  },
];

const currentSlug = Astro.url.pathname.replace('/zinc/docs/', '').replace(/\/$/, '');

function isActive(slug: string): boolean {
  return currentSlug === slug || currentSlug.startsWith(`${slug}/`);
}
---

<BaseLayout title={title} description={metaDescription} keywords={keywords} jsonLd={jsonLd}>
  <Breadcrumbs items={breadcrumbItems} />
  <div class="doc-layout wide">
    <aside class="doc-nav">
      <h3><a href="/zinc/docs">Docs</a></h3>
      {docNavSections.map(section => (
        <div class="doc-nav-section">
          <p class="doc-nav-label">{section.label}</p>
          <ul>
            {section.items.map(item => (
              <li>
                <a href={`/zinc/docs/${item.slug}`} class:list={[{ active: isActive(item.slug) }]}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </aside>
    <article class="doc-content">
      {lastmod && <p class="lastmod">Last updated: {lastmod}</p>}
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .doc-layout {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--space-xl);
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .wide {
    /* Break out of the narrow .container */
    width: 100vw;
    max-width: var(--max-width-wide);
    margin-left: calc(50% - min(50vw, var(--max-width-wide) / 2));
    padding: 0 var(--space-md);
  }

  .doc-nav h3 {
    font-size: 0.9rem;
    margin-bottom: var(--space-sm);
  }

  .doc-nav h3 a {
    color: var(--color-text);
  }

  .doc-nav {
    position: sticky;
    top: 1rem;
    align-self: start;
  }

  .doc-nav-section + .doc-nav-section {
    margin-top: var(--space-lg);
  }

  .doc-nav-label {
    margin: 0 0 var(--space-xs);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .doc-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .doc-nav li {
    margin-bottom: var(--space-xs);
  }

  .doc-nav a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .doc-nav a:hover,
  .doc-nav a.active {
    color: var(--color-accent);
    text-decoration: none;
  }

  .lastmod {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .doc-content {
    min-width: 0;
  }

  @media (max-width: 700px) {
    .doc-layout {
      grid-template-columns: 1fr;
    }

    .doc-nav {
      position: static;
    }

    .doc-nav ul {
      display: flex;
      gap: var(--space-md);
      flex-wrap: wrap;
    }
  }
</style>
