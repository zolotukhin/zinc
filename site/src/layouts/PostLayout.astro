---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { buildBreadcrumbList } from '../lib/structured-data';

interface PostLink {
  slug: string;
  title: string;
  excerpt: string;
}

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  tags?: string[];
  keywords?: string[];
  prevPost?: PostLink | null;
  nextPost?: PostLink | null;
}

const { title, date, excerpt, tags, keywords, prevPost, nextPost } = Astro.props;

const isoDate = date.toISOString().split('T')[0];
const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
}).format(date);
const keywordList = keywords && keywords.length > 0 ? keywords : tags ?? [];

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://zolotukhin.ai';
const canonicalUrl = Astro.url.href;
const xStarters = [
  `Interesting read:`,
  `Worth a look:`,
  `Good writeup on`,
  `This was a fun read:`,
  `Check this out:`,
];
const xShareText = `${xStarters[Math.floor(Math.random() * xStarters.length)]} ${title}`;
const xIntentUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(xShareText)}&url=${encodeURIComponent(canonicalUrl)}`;
const breadcrumbItems = [
  { name: 'Home', href: '/' },
  { name: 'Blog', href: '/blog' },
  { name: title },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      headline: title,
      datePublished: isoDate,
      author: {
        '@type': 'Person',
        name: 'Stepan Zolotukhin',
        url: `${siteUrl}/about`,
      },
      publisher: {
        '@type': 'Organization',
        name: 'ZINC Project',
        url: siteUrl,
      },
      description: excerpt,
      url: Astro.url.href,
      keywords: keywordList,
      mainEntityOfPage: Astro.url.href,
    },
    buildBreadcrumbList(siteUrl, breadcrumbItems),
  ],
};
---

<BaseLayout
  title={title}
  description={excerpt}
  keywords={keywordList.length > 0 ? keywordList.join(', ') : undefined}
  ogType="article"
  publishedDate={isoDate}
  tags={tags}
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} />
  <article class="post">
    <header class="post-header">
      <time datetime={isoDate}>{formattedDate}</time>
      <h1>{title}</h1>
      {tags && tags.length > 0 && (
        <div class="tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
      <a
        href={xIntentUrl}
        class="post-share-link"
        target="_blank"
        rel="noopener noreferrer"
        data-share-x
        data-copy-url={canonicalUrl}
      >
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        Discuss on X
      </a>
      <span class="post-share-status" data-share-status aria-live="polite"></span>
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
  {(prevPost || nextPost) && (
    <nav class="post-nav-grid">
      {prevPost ? (
        <a href={`/blog/${prevPost.slug}`} class="nav-card nav-prev">
          <span class="nav-label">&larr; Previous</span>
          <span class="nav-title">{prevPost.title}</span>
          <span class="nav-excerpt">{prevPost.excerpt.slice(0, 120)}{prevPost.excerpt.length > 120 ? '...' : ''}</span>
        </a>
      ) : <div />}
      {nextPost ? (
        <a href={`/blog/${nextPost.slug}`} class="nav-card nav-next">
          <span class="nav-label">Next &rarr;</span>
          <span class="nav-title">{nextPost.title}</span>
          <span class="nav-excerpt">{nextPost.excerpt.slice(0, 120)}{nextPost.excerpt.length > 120 ? '...' : ''}</span>
        </a>
      ) : <div />}
    </nav>
  )}
  <nav class="post-nav">
    <a href="/blog">&larr; All posts</a>
  </nav>
  <div class="lightbox" id="lightbox">
    <img src="" alt="" />
  </div>
</BaseLayout>

<script is:inline>
  (function() {
    var lb = document.getElementById('lightbox');
    if (!lb) return;
    var lbImg = lb.querySelector('img');

    document.querySelectorAll('.post-content img').forEach(function(img) {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', function() {
        lbImg.src = img.src;
        lbImg.alt = img.alt;
        lb.classList.add('active');
      });
    });

    lb.addEventListener('click', function() {
      lb.classList.remove('active');
    });

    document.querySelectorAll('[data-share-x]').forEach(function(link) {
      var status = link.parentElement && link.parentElement.querySelector('[data-share-status]');
      var resetStatus = function() {
        if (!status) return;
        window.setTimeout(function() {
          status.textContent = '';
        }, 2400);
      };

      link.addEventListener('click', function() {
        if (!status) return;
        status.textContent = 'Opening X...';

        var copyUrl = link.getAttribute('data-copy-url');
        if (!copyUrl || !navigator.clipboard || !navigator.clipboard.writeText) {
          resetStatus();
          return;
        }

        navigator.clipboard.writeText(copyUrl).then(function() {
          status.textContent = 'Link copied. Opening X...';
          resetStatus();
        }).catch(function() {
          resetStatus();
        });
      });
    });
  })();
</script>

<style is:global>
  .post-header {
    margin-bottom: var(--space-xl);
  }

  .post-header time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .post-header h1 {
    margin-top: var(--space-xs);
  }

  .tags {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    padding: 0.1em 0.5em;
    border-radius: 3px;
  }

  .post-content {
    line-height: 1.8;
  }

  .post-share-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.6rem;
    padding: 0.3rem 0.65rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1;
    text-decoration: none;
  }

  .post-share-link:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
    text-decoration: none;
  }

  .post-share-status {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    min-height: 1em;
    margin-top: 0.25rem;
  }

  /* Single images: compact, centered */
  .post-content img {
    display: block;
    max-width: 380px;
    width: 100%;
    height: auto;
    border-radius: 6px;
    margin: var(--space-md) auto;
  }

  .post-content figure.diagram-card {
    margin: var(--space-lg) 0;
  }

  .post-content figure.diagram-wide {
    margin-left: 0;
    margin-right: 0;
  }

  .post-content figure.diagram-compact {
    max-width: 28rem;
    margin-left: auto;
    margin-right: auto;
  }

  .post-content figure.diagram-compact .flow-diagram {
    gap: 0.72rem;
    padding: 0.85rem;
  }

  .post-content figure.diagram-compact .flow-node {
    width: min(100%, 22rem);
    padding: 0.56rem 0.72rem;
    font-size: 0.86rem;
  }

  .post-content figure.diagram-compact .flow-arrow {
    font-size: 0.92rem;
  }

  .post-content figure.diagram-compact .flow-pill {
    padding: 0.42rem 0.68rem;
    font-size: 0.75rem;
  }

  .post-content figure.diagram-card img {
    max-width: 100%;
    width: 100%;
    margin: 0;
    border-radius: 12px;
  }

  .post-content figure.diagram-card figcaption {
    margin-top: 0.65rem;
    padding: 0 0.15rem;
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    text-align: left;
  }

  .post-content .flow-diagram {
    display: grid;
    gap: 0.9rem;
    margin: 0;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--color-accent) 10%, transparent), transparent 42%),
      var(--color-bg-alt);
  }

  .post-content .flow-main {
    display: grid;
    justify-items: center;
    gap: 0.45rem;
  }

  .post-content .flow-node {
    width: min(100%, 28rem);
    padding: 0.68rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg);
    text-align: center;
    font-size: 0.92rem;
    line-height: 1.35;
    font-weight: 600;
  }

  .post-content .flow-node-accent {
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-border));
    color: var(--color-accent);
  }

  .post-content .flow-node-output {
    background: color-mix(in srgb, var(--color-accent) 9%, var(--color-bg));
  }

  .post-content .flow-arrow {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1;
  }

  .post-content .flow-branches {
    display: grid;
    gap: 0.55rem;
    padding-top: 0.15rem;
    border-top: 1px dashed var(--color-border);
  }

  .post-content .flow-branch-label {
    text-align: center;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .post-content .flow-branch-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .post-content .flow-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.48rem 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg);
    font-size: 0.8rem;
    line-height: 1.2;
    color: var(--color-text-muted);
  }

  .post-content .flow-plus {
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .post-content figure.diagram-dual .diagram-mobile-alt {
    display: none;
    margin: 0;
    padding: 1rem 1.05rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg-alt);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.55;
    white-space: pre;
    overflow-x: auto;
  }

  /* Image pair grid: two images side by side */
  .post-content .img-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
    margin: var(--space-md) 0;
  }

  /* Kill the <p> wrapper markdown inserts inside img-pair */
  .post-content .img-pair p {
    display: contents;
  }

  .post-content .img-pair img {
    max-width: 100%;
    margin: 0;
    width: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  @media (max-width: 600px) {
    .post-content img {
      max-width: 100%;
    }

    .post-content figure.diagram-dual .diagram-visual {
      display: none;
    }

    .post-content figure.diagram-dual .diagram-mobile-alt {
      display: block;
      font-size: 0.74rem;
    }

    .post-content .flow-diagram {
      padding: 0.85rem;
    }

    .post-content .flow-node {
      font-size: 0.86rem;
      width: 100%;
    }

    .post-content .flow-branch-row {
      gap: 0.4rem;
    }

    .post-content .flow-pill {
      font-size: 0.75rem;
    }

    .post-content .img-pair {
      grid-template-columns: 1fr;
    }
    .post-content .img-pair img {
      aspect-ratio: auto;
    }
  }

  .post-nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    color: var(--color-text);
    transition: border-color 0.15s ease;
  }

  .nav-card:hover {
    text-decoration: none;
    border-color: var(--color-accent);
  }

  .nav-next {
    text-align: right;
  }

  .nav-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .nav-title {
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.3;
  }

  .nav-excerpt {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  @media (max-width: 600px) {
    .post-nav-grid {
      grid-template-columns: 1fr;
    }
  }

  .post-nav {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    text-align: center;
  }

  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.85);
    cursor: zoom-out;
    align-items: center;
    justify-content: center;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox img {
    max-width: 90vw;
    max-height: 90vh;
    border-radius: 8px;
    object-fit: contain;
  }
</style>
