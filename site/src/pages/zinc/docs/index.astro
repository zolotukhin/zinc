---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { buildBreadcrumbList } from '../../../lib/structured-data';
import { loadDocs } from '../../../lib/docs-loader';
import { loadZigApi } from '../../../lib/zig-api-loader';

const docs = await loadDocs();
const zigApi = await loadZigApi();
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://zolotukhin.ai';
const breadcrumbItems = [
  { name: 'Home', href: '/' },
  { name: 'ZINC', href: '/zinc' },
  { name: 'Docs' },
];

const docMeta: Record<string, { label: string; description: string; order: number }> = {
  spec: {
    label: 'Technical Specification',
    description: 'Architecture, GPU kernels, model support, scheduler behavior',
    order: 1,
  },
  'turboquant-spec': {
    label: 'TurboQuant Compression',
    description: 'Two-stage vector quantization and KV cache memory reduction',
    order: 2,
  },
  'rdna4-tuning': {
    label: 'RDNA4 Tuning Guide',
    description: 'Cooperative matrix, bandwidth tuning, SPIR-V toolchain',
    order: 3,
  },
  api: {
    label: 'Serving HTTP API',
    description: 'OpenAI-compatible request/response shapes for clients',
    order: 4,
  },
  'gpu-reference': {
    label: 'GPU Reference',
    description: 'RDNA3/RDNA4 hardware specs, ISA, memory hierarchy',
    order: 5,
  },
};

const supplementalDocs = [...docs].sort((a, b) => {
  const aOrder = docMeta[a.slug]?.order ?? 99;
  const bOrder = docMeta[b.slug]?.order ?? 99;
  return aOrder - bOrder;
});

const combinedDocs = [
  {
    label: 'ZINC Zig API',
    href: '/zinc/docs/zig-api',
    description: 'Primary generated reference built from src/**/*.zig with module sections, symbol anchors, and source links.',
  },
  ...supplementalDocs.map(doc => ({
    label: docMeta[doc.slug]?.label ?? doc.title,
    href: `/zinc/docs/${doc.slug}`,
    description: docMeta[doc.slug]?.description ?? 'ZINC documentation',
  })),
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: 'ZINC Documentation',
      description: 'Documentation for the ZINC inference engine centered on the generated Zig API reference, with supplemental architecture, tuning, and protocol docs.',
      url: `${siteUrl}/zinc/docs`,
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: combinedDocs.map((doc, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: doc.label,
          url: `${siteUrl}${doc.href}`,
        })),
      },
    },
    buildBreadcrumbList(siteUrl, breadcrumbItems),
  ],
};
---

<BaseLayout
  title="ZINC Documentation"
  description="Documentation for the ZINC inference engine centered on the generated Zig API reference, with supplemental architecture, tuning, and protocol docs."
  keywords="ZINC documentation, Zig API, Vulkan compute, GGUF, AMD GPU inference, TurboQuant, RDNA4 tuning, OpenAI-compatible API"
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} />

  <div class="docs-hub">
    <header class="hub-header">
      <h1>Documentation</h1>
      <p>Start with the Zig API for the runtime internals, or jump to any spec below.</p>
    </header>

    <div class="hub-grid">
      <a href="/zinc/docs/zig-api" class="card card-primary">
        <div class="card-head">
          <h2>Zig API Reference</h2>
          <span class="badge">Primary</span>
        </div>
        <p>Generated from <code>src/**/*.zig</code></p>
        <div class="card-stats">
          <span>{zigApi.sections.length} sections</span>
          <span>{zigApi.moduleCount} modules</span>
          <span>{zigApi.exportCount} exports</span>
        </div>
      </a>

      {supplementalDocs.map(doc => (
        <a href={`/zinc/docs/${doc.slug}`} class="card">
          <h2>{docMeta[doc.slug]?.label ?? doc.title}</h2>
          <p>{docMeta[doc.slug]?.description}</p>
        </a>
      ))}
    </div>

    <div class="hub-sections">
      <h3>API Sections</h3>
      <div class="section-list">
        {zigApi.sections.map(section => (
          <a href={`/zinc/docs/zig-api#${section.slug}`} class="section-link">
            <span class="section-name">{section.title}</span>
            <span class="section-meta">{section.modules.length} modules, {section.symbolCount} symbols</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .docs-hub {
    max-width: 960px;
    margin: 0 auto;
  }

  .hub-header {
    margin-bottom: var(--space-lg);
  }

  .hub-header h1 {
    margin-bottom: var(--space-xs);
  }

  .hub-header p {
    color: var(--color-text-muted);
    margin: 0;
  }

  .hub-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .card {
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    color: var(--color-text);
    transition: border-color 0.15s ease;
  }

  .card:hover {
    text-decoration: none;
    border-color: var(--color-accent);
  }

  .card-primary {
    grid-column: 1 / -1;
    background:
      linear-gradient(135deg, rgba(211, 84, 0, 0.08), transparent 50%),
      var(--color-bg);
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .card h2 {
    font-size: 1rem;
    margin: 0 0 var(--space-xs);
  }

  .card-primary h2 {
    font-size: 1.15rem;
    margin: 0;
  }

  .badge {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: var(--color-accent);
    color: white;
  }

  .card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: var(--space-xs) 0 0;
    flex: 1;
  }

  .card-stats {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
    margin-top: var(--space-sm);
  }

  .card-stats span {
    font-size: 0.75rem;
    padding: 0.15rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    background: var(--color-bg-alt);
  }

  .hub-sections {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: var(--space-md);
  }

  .hub-sections h3 {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-sm);
  }

  .section-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
    border-radius: 6px;
    overflow: hidden;
  }

  .section-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.55rem 0.75rem;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.88rem;
    transition: background 0.1s ease;
  }

  .section-link:hover {
    text-decoration: none;
    background: var(--color-bg-alt);
  }

  .section-name {
    font-weight: 500;
  }

  .section-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    margin-left: var(--space-sm);
  }

  @media (max-width: 700px) {
    .hub-grid {
      grid-template-columns: 1fr;
    }
    .card-primary {
      grid-column: 1;
    }
    .section-list {
      grid-template-columns: 1fr;
    }
  }
</style>
