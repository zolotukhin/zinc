---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { buildBreadcrumbList } from '../../../lib/structured-data';
import { loadDocs } from '../../../lib/docs-loader';

const docs = await loadDocs();
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://zolotukhin.ai';
const breadcrumbItems = [
  { name: 'Home', href: '/' },
  { name: 'ZINC', href: '/zinc' },
  { name: 'Docs' },
];

const docMeta: Record<string, { label: string; description: string; order: number }> = {
  'spec': { label: 'ZINC Technical Specification', description: 'Architecture, GPU kernels, model loading, request scheduler, paged KV cache, and OpenAI-compatible API for AMD RDNA3/RDNA4.', order: 1 },
  'turboquant-spec': { label: 'TurboQuant KV Cache Compression', description: 'Two-stage vector quantization — Lloyd-Max codebooks, QJL residual correction, 5x memory reduction at 3-bit on Vulkan compute.', order: 2 },
  'rdna4-tuning': { label: 'RDNA4 GPU Tuning Guide', description: 'Performance profiling for AI PRO R9700 and RX 9070 — ECC, cooperative matrix, wave64, SPIR-V toolchain, bandwidth optimization.', order: 3 },
  'api': { label: 'ZINC API Reference', description: 'OpenAI-compatible HTTP API — chat completions, text completion, embeddings, model listing, and GPU health endpoints.', order: 4 },
};

const sortedDocs = docs.sort((a, b) => {
  const aOrder = docMeta[a.slug]?.order ?? 99;
  const bOrder = docMeta[b.slug]?.order ?? 99;
  return aOrder - bOrder;
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: 'ZINC Documentation',
      description: 'Technical documentation for the ZINC LLM inference engine — Vulkan compute shaders, TurboQuant KV compression, RDNA4 tuning, and OpenAI-compatible API.',
      url: `${siteUrl}/zinc/docs`,
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: sortedDocs.map((doc, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: docMeta[doc.slug]?.label ?? doc.title,
          url: `${siteUrl}/zinc/docs/${doc.slug}`,
        })),
      },
    },
    buildBreadcrumbList(siteUrl, breadcrumbItems),
  ],
};
---

<BaseLayout
  title="ZINC Documentation"
  description="Technical documentation for the ZINC LLM inference engine — Vulkan compute shaders, TurboQuant KV compression, RDNA4 tuning, and OpenAI-compatible API."
  keywords="ZINC documentation, LLM inference docs, Vulkan compute, TurboQuant, RDNA4 tuning, OpenAI API reference, AMD GPU inference, Zig, GLSL shaders, GGUF"
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} />
  <h1>Documentation</h1>
  <p class="intro">Technical documentation for the ZINC inference engine — Zig + Vulkan compute for AMD RDNA3/RDNA4 GPUs.</p>

  <div class="doc-list">
    {sortedDocs.map(doc => (
      <a href={`/zinc/docs/${doc.slug}`} class="doc-item">
        <h2>{docMeta[doc.slug]?.label ?? doc.title}</h2>
        <p>{docMeta[doc.slug]?.description ?? 'ZINC documentation'}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .intro {
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .doc-list {
    display: grid;
    gap: var(--space-md);
  }

  .doc-item {
    display: block;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    transition: border-color 0.15s;
  }

  .doc-item:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .doc-item h2 {
    font-size: 1.1rem;
    margin: 0 0 var(--space-xs);
  }

  .doc-item p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
