---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import DocsSearch from '../../../components/DocsSearch.astro';
import TerminalWindow from '../../../components/TerminalWindow.astro';
import { buildBreadcrumbList } from '../../../lib/structured-data';
import { loadDocs } from '../../../lib/docs-loader';
import { loadZigApi } from '../../../lib/zig-api-loader';

const docs = await loadDocs();
const zigApi = await loadZigApi();
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://zolotukhin.ai';
const breadcrumbItems = [
  { name: 'Home', href: '/' },
  { name: 'ZINC', href: '/zinc' },
  { name: 'Docs' },
];

const docMeta: Record<string, { label: string; description: string; order: number }> = {
  'getting-started': { label: 'Getting Started', description: 'Build ZINC, verify Vulkan, and run the first prompt.', order: 1 },
  'hardware-requirements': { label: 'Hardware Requirements', description: 'Linux, AMD GPU, Vulkan, VRAM, and system expectations.', order: 2 },
  'running-zinc': { label: 'Running ZINC', description: 'CLI usage, server mode, KV quantization, and graph exports.', order: 3 },
  api: { label: 'Serving HTTP API', description: 'OpenAI-compatible request and response shapes.', order: 4 },
  spec: { label: 'Technical Specification', description: 'Architecture, kernels, model support, and scheduler behavior.', order: 10 },
  'rdna4-tuning': { label: 'RDNA4 Tuning Guide', description: 'Cooperative matrix, bandwidth tuning, and toolchain notes.', order: 11 },
  'gpu-reference': { label: 'GPU Reference', description: 'RDNA3 and RDNA4 hardware specs, ISA, and memory hierarchy.', order: 12 },
  'turboquant-spec': { label: 'TurboQuant Compression', description: 'Two-stage vector quantization and KV cache reduction.', order: 13 },
  'apple-silicon-mlx-reference': { label: 'Apple Silicon + MLX Reference', description: 'Metal GPU families, MLX architecture, M1–M5 capabilities, and MSL kernel optimization.', order: 14 },
};

const orderedDocs = [...docs].sort((a, b) => (docMeta[a.slug]?.order ?? 99) - (docMeta[b.slug]?.order ?? 99));
const startHere = orderedDocs.filter(doc => ['getting-started', 'hardware-requirements', 'running-zinc', 'api'].includes(doc.slug));
const deepDocs = orderedDocs.filter(doc => !['getting-started', 'hardware-requirements', 'running-zinc', 'api'].includes(doc.slug));

const combinedDocs = [
  ...startHere.map(doc => ({ label: docMeta[doc.slug]?.label ?? doc.title, href: `/zinc/docs/${doc.slug}` })),
  ...deepDocs.map(doc => ({ label: docMeta[doc.slug]?.label ?? doc.title, href: `/zinc/docs/${doc.slug}` })),
  { label: 'ZINC Zig API', href: '/zinc/docs/zig-api' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: 'ZINC Documentation',
      description: 'Documentation for using ZINC on AMD GPUs: getting started, hardware requirements, running the engine, then deeper tuning and reference material.',
      url: `${siteUrl}/zinc/docs`,
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: combinedDocs.map((doc, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: doc.label,
          url: `${siteUrl}${doc.href}`,
        })),
      },
    },
    buildBreadcrumbList(siteUrl, breadcrumbItems),
  ],
};
---

<BaseLayout
  title="ZINC Documentation"
  description="Documentation for using ZINC on AMD GPUs: getting started, hardware requirements, running the CLI and server, plus architecture, tuning, and API reference."
  keywords="ZINC docs, ZINC getting started, ZINC hardware requirements, how to run ZINC, AMD GPU inference docs, Vulkan GGUF docs, ZINC API, RDNA4 tuning"
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} />

  <div class="docs-hub">
    <header class="hub-header">
      <h1>Documentation</h1>
      <p>Start with how to actually use ZINC: confirm the hardware, build the binary, run one model, then go deeper into tuning and internals.</p>
    </header>

    <section class="search-panel">
      <DocsSearch />
    </section>

    <section class="status-banner">
      <div>
        <p class="kicker">Current Status</p>
        <h2>Experimental and under active development</h2>
        <p>The CLI path is the best-supported way to use ZINC today. Linux on AMD RDNA3 or RDNA4 is the intended environment. Server mode and broader model coverage are still evolving.</p>
      </div>
      <a href="https://github.com/zolotukhin/zinc" class="status-link">View source</a>
    </section>

    <section class="quickstart-panel">
      <TerminalWindow
        title="bash"
        code={`# Fastest path: build ZINC, see which supported models fit,
# pull one, and run it end to end.
git clone https://github.com/zolotukhin/zinc.git
cd zinc
zig build -Doptimize=ReleaseFast
export RADV_PERFTEST=coop_matrix

# Verify Vulkan, shaders, and the runtime path first
./zig-out/bin/zinc --check

# Show supported models for this machine
./zig-out/bin/zinc model list

# Pull one managed model from the built-in catalog
./zig-out/bin/zinc model pull qwen35-2b-q4k-m

# Check the managed model before the first run
./zig-out/bin/zinc --check --model-id qwen35-2b-q4k-m

# Run a prompt with that managed model
./zig-out/bin/zinc \\
  --model-id qwen35-2b-q4k-m \\
  --prompt "The capital of France is"

# If you already have a local GGUF file, use it directly instead
./zig-out/bin/zinc --check -m /path/to/model.gguf
./zig-out/bin/zinc \\
  -m /path/to/model.gguf \\
  --prompt "The capital of France is"`}
      />
    </section>

    <section class="group">
      <div class="group-head">
        <h2>Start Here</h2>
        <p>The practical docs for getting ZINC onto a real machine and actually running it.</p>
      </div>
      <div class="grid start-grid">
        {startHere.map(doc => (
          <a href={`/zinc/docs/${doc.slug}`} class:list={['card', { primary: doc.slug === 'getting-started' }]}>
            <div class="card-head">
              <h3>{docMeta[doc.slug]?.label ?? doc.title}</h3>
              {doc.slug === 'getting-started' && <span class="badge">First</span>}
            </div>
            <p>{docMeta[doc.slug]?.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="group">
      <div class="group-head">
        <h2>Deep Docs</h2>
        <p>The architecture, tuning, and reference material once the runtime path is already clear.</p>
      </div>
      <div class="grid deep-grid">
        {deepDocs.map(doc => (
          <a href={`/zinc/docs/${doc.slug}`} class="card">
            <h3>{docMeta[doc.slug]?.label ?? doc.title}</h3>
            <p>{docMeta[doc.slug]?.description}</p>
          </a>
        ))}
        <a href="/zinc/docs/zig-api" class="card api-card">
          <div class="card-head">
            <h3>Zig API Reference</h3>
            <span class="badge">Generated</span>
          </div>
          <p>Reference built from <code>src/**/*.zig</code>, with module pages, symbol anchors, and source links.</p>
          <div class="card-stats">
            <span>{zigApi.sections.length} sections</span>
            <span>{zigApi.moduleCount} modules</span>
            <span>{zigApi.exportCount} exports</span>
          </div>
        </a>
      </div>
    </section>

    <section class="api-sections">
      <h3>Zig API Sections</h3>
      <div class="section-list">
        {zigApi.sections.map(section => (
          <a href={`/zinc/docs/zig-api#${section.slug}`} class="section-link">
            <span class="section-name">{section.title}</span>
            <span class="section-meta">{section.modules.length} modules, {section.symbolCount} symbols</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .docs-hub {
    width: 100vw;
    max-width: 1220px;
    margin-left: calc(50% - min(50vw, 610px));
    padding: 0 var(--space-lg);
  }
  .hub-header { margin-bottom: var(--space-lg); }
  .hub-header h1 { margin-bottom: var(--space-xs); }
  .hub-header p, .group-head p, .status-banner p { margin: 0; color: var(--color-text-muted); }
  .kicker { margin: 0 0 var(--space-xs); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-accent); }
  .status-banner { display: grid; grid-template-columns: 1fr auto; gap: var(--space-md); align-items: start; padding: var(--space-md); margin: var(--space-lg) 0; border: 1px solid var(--color-border); border-radius: 14px; background: radial-gradient(circle at top right, rgba(211, 84, 0, 0.12), transparent 38%), var(--color-bg-alt); }
  .status-banner h2, .group-head h2 { margin: 0 0 var(--space-xs); font-size: 1.2rem; }
  .status-link, .card, .section-link { color: var(--color-text); }
  .status-link { display: inline-flex; align-items: center; justify-content: center; align-self: center; padding: 0.55rem 0.9rem; border: 1px solid var(--color-border); border-radius: 999px; white-space: nowrap; }
  .status-link:hover, .card:hover, .section-link:hover { text-decoration: none; border-color: var(--color-accent); }
  .search-panel { margin: 0 0 var(--space-lg); }
  .quickstart-panel { margin-bottom: var(--space-xl); }
  .group + .group { margin-top: var(--space-xl); }
  .group-head { margin-bottom: var(--space-md); }
  .grid { display: grid; gap: var(--space-sm); }
  .start-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .deep-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .card { display: flex; flex-direction: column; padding: var(--space-md); border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-bg); transition: border-color 0.15s ease; }
  .card.primary { background: linear-gradient(135deg, rgba(211, 84, 0, 0.08), transparent 50%), var(--color-bg); }
  .api-card { background: linear-gradient(135deg, rgba(211, 84, 0, 0.06), transparent 55%), var(--color-bg); }
  .card-head { display: flex; align-items: center; gap: var(--space-sm); }
  .card h3 { font-size: 1rem; margin: 0 0 var(--space-xs); }
  .card p { margin: var(--space-xs) 0 0; font-size: 0.85rem; color: var(--color-text-muted); flex: 1; }
  .badge { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.15rem 0.5rem; border-radius: 999px; background: var(--color-accent); color: white; }
  .card-stats { display: flex; gap: var(--space-xs); flex-wrap: wrap; margin-top: var(--space-sm); }
  .card-stats span { font-size: 0.75rem; padding: 0.15rem 0.55rem; border: 1px solid var(--color-border); border-radius: 999px; color: var(--color-text-muted); background: var(--color-bg-alt); }
  .api-sections { margin-top: var(--space-xl); border: 1px solid var(--color-border); border-radius: 10px; padding: var(--space-md); }
  .api-sections h3 { font-size: 0.85rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-text-muted); margin: 0 0 var(--space-sm); }
  .section-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1px; background: var(--color-border); border-radius: 6px; overflow: hidden; }
  .section-link { display: flex; justify-content: space-between; align-items: center; padding: 0.55rem 0.75rem; background: var(--color-bg); font-size: 0.88rem; transition: background 0.1s ease; }
  .section-link:hover { background: var(--color-bg-alt); }
  .section-name { font-weight: 500; }
  .section-meta { font-size: 0.75rem; color: var(--color-text-muted); white-space: nowrap; margin-left: var(--space-sm); }
  @media (max-width: 1100px) {
    .docs-hub {
      max-width: 1080px;
      margin-left: calc(50% - min(50vw, 540px));
      padding: 0 var(--space-md);
    }
  }
  @media (max-width: 900px) { .start-grid, .deep-grid, .section-list { grid-template-columns: 1fr; } }
  @media (max-width: 700px) { .status-banner { grid-template-columns: 1fr; } }
</style>
