---
import DocLayout from '../../../layouts/DocLayout.astro';
import { loadDocs } from '../../../lib/docs-loader';
import { unified } from 'unified';
import remarkParse from 'remark-parse';
import remarkGfm from 'remark-gfm';
import remarkMath from 'remark-math';
import remarkRehype from 'remark-rehype';
import rehypeKatex from 'rehype-katex';
import rehypeShiki from '@shikijs/rehype';
import rehypeStringify from 'rehype-stringify';

function extractHeadingText(node: any): string {
  if (!node || typeof node !== 'object') return '';
  if (node.type === 'text' || node.type === 'inlineCode') return String(node.value ?? '');
  if (!Array.isArray(node.children)) return '';
  return node.children.map(extractHeadingText).join('');
}

function slugifyHeading(text: string): string {
  const normalized = text
    .toLowerCase()
    .normalize('NFKD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
  return normalized || 'section';
}

function rehypeDocHeadingAnchors() {
  return (tree: any) => {
    const seen = new Map<string, number>();

    const walk = (node: any) => {
      if (!node || typeof node !== 'object') return;
      if (node.type === 'element' && typeof node.tagName === 'string' && /^h[1-6]$/.test(node.tagName)) {
        const headingText = extractHeadingText(node).trim();
        if (headingText.length > 0) {
          const existingId = typeof node.properties?.id === 'string' ? node.properties.id : null;
          let slug = existingId ?? slugifyHeading(headingText);
          if (!existingId) {
            const count = seen.get(slug) ?? 0;
            seen.set(slug, count + 1);
            if (count > 0) slug = `${slug}-${count + 1}`;
          }
          node.properties = { ...(node.properties ?? {}), id: slug };
          node.children = [
            ...(node.children ?? []),
            {
              type: 'element',
              tagName: 'a',
              properties: {
                href: `#${slug}`,
                className: ['heading-anchor'],
                'aria-label': `Link to section ${headingText}`,
              },
              children: [{ type: 'text', value: '#' }],
            },
          ];
        }
      }
      if (Array.isArray(node.children)) {
        for (const child of node.children) walk(child);
      }
    };

    walk(tree);
  };
}

export async function getStaticPaths() {
  const docMeta: Record<string, { title: string; description: string; keywords: string }> = {
    'getting-started': {
      title: 'Getting Started with ZINC',
      description: 'How to build ZINC, verify the Vulkan environment, load a GGUF model, and run your first prompt on AMD GPUs. Includes the current experimental caveats and recommended first steps.',
      keywords: 'ZINC getting started, how to use ZINC, run ZINC, build ZINC, ZINC quick start, AMD GPU inference setup, GGUF on AMD GPU, Vulkan inference getting started',
    },
    'hardware-requirements': {
      title: 'ZINC Hardware Requirements',
      description: 'Supported AMD GPUs, Vulkan requirements, Linux expectations, VRAM guidance, and machine sizing for running ZINC locally.',
      keywords: 'ZINC hardware requirements, AMD GPU requirements, RX 9070 XT inference, Radeon AI PRO R9700 inference, ZINC Vulkan requirements, ZINC Linux requirements, GGUF hardware guide',
    },
    'running-zinc': {
      title: 'Running ZINC',
      description: 'CLI usage, GPU selection, KV quantization, graph export, and the current experimental server path for ZINC on AMD GPUs.',
      keywords: 'running ZINC, ZINC CLI, ZINC server, ZINC --prompt, ZINC kv quant, ZINC graph export, ZINC OpenAI API, AMD Vulkan inference CLI',
    },
    'spec': {
      title: 'ZINC Technical Specification',
      description: 'GPU kernel library, model loading, request scheduler, paged KV cache, and OpenAI-compatible API for AMD RDNA3/RDNA4 Vulkan inference.',
      keywords: 'ZINC spec, GPU kernel, DMMV, matmul, flash attention, paged KV cache, continuous batching, GGUF, Vulkan compute, RDNA4, RDNA3, RX 9070, Radeon AI PRO R9700, OpenAI API, Zig, GLSL, SPIR-V, cooperative matrix, LLaMA, Qwen, Mamba, MoE',
    },
    'turboquant-spec': {
      title: 'TurboQuant KV Cache Compression',
      description: 'Two-stage vector quantization for LLM KV cache — Lloyd-Max codebooks, QJL residual correction, 5x compression at 3-bit with unbiased attention on Vulkan compute.',
      keywords: 'TurboQuant, KV cache compression, vector quantization, Lloyd-Max, QJL, quantized attention, LLM memory optimization, Vulkan compute, RDNA4, 3-bit quantization, paged attention, VRAM optimization, RX 9070 XT, inference memory, ICLR 2026',
    },
    'rdna4-tuning': {
      title: 'RDNA4 GPU Tuning Guide',
      description: 'Performance profiling for AI PRO R9700 and RX 9070 — ECC, cooperative matrix, wave64, SPIR-V toolchain, bandwidth optimization.',
      keywords: 'RDNA4 tuning, AMD GPU profiling, Radeon AI PRO R9700, RX 9070, wave64, cooperative matrix, GPU ECC, RADV, AMDVLK, SPIR-V, glslc, bandwidth utilization, LLM inference performance, Vulkan optimization, gfx1201',
    },
    'gpu-reference': {
      title: 'AMD RDNA3/RDNA4 GPU Reference for Inference',
      description: 'Hardware specs, ISA opcodes, WMMA matrix cores, memory hierarchy, wave execution, register allocation, and Vulkan compute details for AMD RX 9070 XT, RX 7900 XTX, and Radeon AI PRO R9700.',
      keywords: 'RDNA4 specs, RDNA3 specs, gfx1201, gfx1100, RX 9070 XT specs, RX 7900 XTX specs, Radeon AI PRO R9700 specs, AMD GPU ISA, WMMA, wave64, wave32, cooperative matrix, VGPR, LDS, compute unit, Vulkan dispatch, DMMV, V_FMA_F32, V_DOT2_F32_F16, memory bandwidth, GPU ECC, RADV, SPIR-V',
    },
    'api': {
      title: 'ZINC API Reference',
      description: 'OpenAI-compatible HTTP API — chat completions, text completion, embeddings, model listing, and GPU health endpoints for local LLM inference.',
      keywords: 'ZINC API, OpenAI compatible, chat completions, SSE streaming, local LLM API, inference server, v1/chat/completions, embeddings API, health endpoint, self-hosted LLM, AMD GPU inference API',
    },
  };

  const docs = await loadDocs();
  return docs.map(doc => ({
    params: { slug: doc.slug },
    props: {
      doc,
      meta: docMeta[doc.slug],
    },
  }));
}

const { doc, meta } = Astro.props;
const title = meta?.title ?? doc.title;
const description = meta?.description ?? `${title} — ZINC documentation`;
const keywords = meta?.keywords;

// Strip the first H1 heading since DocLayout doesn't render one
// and the markdown's own heading serves as the page title
const content = doc.content;

const contentHtml = String(
  await unified()
    .use(remarkParse)
    .use(remarkGfm)
    .use(remarkMath)
    .use(remarkRehype)
    .use(rehypeKatex)
    .use(rehypeShiki, {
      defaultColor: 'light',
      themes: {
        light: 'github-light',
        dark: 'vitesse-dark',
      },
      langs: ['zig', 'glsl', 'json', 'bash', 'typescript', 'javascript', 'text', 'c'],
    })
    .use(rehypeDocHeadingAnchors)
    .use(rehypeStringify)
    .process(content)
);
---

<DocLayout title={title} description={description} keywords={keywords} lastmod={doc.lastmod}>
  <div set:html={contentHtml} />
</DocLayout>
