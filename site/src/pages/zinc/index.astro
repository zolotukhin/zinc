---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TerminalWindow from '../../components/TerminalWindow.astro';
import { buildBreadcrumbList } from '../../lib/structured-data';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://zolotukhin.ai';
const breadcrumbItems = [
  { name: 'Home', href: '/' },
  { name: 'ZINC' },
];
const discordUrl = 'https://discord.gg/tNDEgTG5s';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'ZINC',
      description: 'LLM inference engine for AMD GPUs and Apple Silicon, built with Zig, Vulkan compute shaders, and Metal. 103.72 tok/s on RDNA4 and 46.36 tok/s on Apple M4 Max for the 35B model.',
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Linux, macOS',
      url: `${siteUrl}/zinc`,
      codeRepository: 'https://github.com/zolotukhin/zinc',
      author: {
        '@type': 'Person',
        name: 'Stepan Zolotukhin',
        url: `${siteUrl}/about`,
      },
      keywords: 'LLM inference, AMD GPU, RDNA4, RDNA3, Vulkan compute, Zig, TurboQuant, KV cache compression, OpenAI API, local AI, vLLM alternative, llama.cpp alternative',
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Does ZINC work on AMD consumer GPUs like the RX 9070 XT?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. ZINC is built specifically for AMD RDNA3 and RDNA4 consumer GPUs including the RX 7900 XTX, RX 9070 XT, and Radeon AI PRO R9700. It uses Vulkan compute instead of ROCm, so it works on hardware that vLLM and most CUDA-based tools cannot use.',
          },
        },
        {
          '@type': 'Question',
          name: 'How does ZINC compare to llama.cpp and vLLM?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'vLLM requires ROCm which does not support RDNA3/RDNA4 consumer GPUs. llama.cpp supports Vulkan and Metal but treats consumer hardware as an afterthought. ZINC is built from scratch with hand-tuned Vulkan shaders for AMD and native Metal shaders for Apple Silicon, plus an OpenAI-compatible API and built-in chat UI.',
          },
        },
        {
          '@type': 'Question',
          name: 'What performance does ZINC achieve on RDNA4 and Apple Silicon?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'On the Radeon AI PRO R9700 (32GB, 576 GB/s), the current validated ZINC plain-decode number is 103.72 tok/s on Qwen3.5-35B-A3B-UD-Q4_K_XL — 1.07x llama.cpp on the same machine. On the current Apple Silicon validation box, a Mac Studio (Mac16,9) with Apple M4 Max, 40-core GPU, and 64 GB unified memory, Qwen3.5-35B-A3B-UD-Q4_K_XL measures 46.36 tok/s decode in the Metal benchmark.',
          },
        },
        {
          '@type': 'Question',
          name: 'What is TurboQuant and how does it help?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'TurboQuant is ZINC\'s KV-compression direction and public implementation spec for 2-4 bit cache compression. It is part of the roadmap and not the reason for the current benchmark numbers on the public site.',
          },
        },
      ],
    },
    buildBreadcrumbList(siteUrl, breadcrumbItems),
  ],
};
---

<BaseLayout
  title="ZINC — LLM Inference Engine"
  description="ZINC is a local LLM inference engine for AMD GPUs and Apple Silicon. 103.72 tok/s on RDNA4 and 46.36 tok/s on Apple M4 Max for the 35B model, with hand-tuned Vulkan and Metal backends."
  keywords="ZINC, LLM inference engine, AMD GPU, RDNA4, RDNA3, RX 9070 XT, RX 7900 XTX, Radeon AI PRO R9700, Vulkan compute, Zig, TurboQuant, KV cache compression, vLLM alternative, llama.cpp alternative, ROCm alternative, OpenAI compatible API, local AI, continuous batching, paged KV cache, GGUF, LLaMA, Qwen, Mistral, Mamba"
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} />
  <section class="hero">
    <img src="/zinc-logo.png" alt="ZINC inference engine logo — lightning bolt on circuit board" class="logo" width="120" height="120" />
    <h1>ZINC — LLM Inference Engine</h1>
    <p class="tagline">Fast local LLM inference on AMD GPUs and Apple Silicon. Hand-tuned Vulkan and Metal shaders, no ROCm, no MLX.</p>
    <div class="hero-links">
      <a href="https://github.com/zolotukhin/zinc" class="hero-link">
        <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        View on GitHub
      </a>
      <a href="/zinc/benchmarks" class="hero-link hero-link-benchmarks">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 19h16"/><path d="M7 16V9"/><path d="M12 16V5"/><path d="M17 16v-4"/></svg>
        Benchmarks
      </a>
      <a href={discordUrl} class="hero-link hero-link-discord">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369A19.791 19.791 0 0015.558 3c-.206.375-.446.872-.61 1.264a18.27 18.27 0 00-5.896 0A12.64 12.64 0 008.44 3a19.736 19.736 0 00-4.76 1.369C.533 9.091-.32 13.699.099 18.243a19.9 19.9 0 005.993 3.03c.486-.665.918-1.368 1.288-2.109-.709-.268-1.388-.602-2.028-.99.17-.124.336-.252.496-.385 3.915 1.84 8.163 1.84 12.032 0 .162.133.328.261.496.385-.642.39-1.323.724-2.033.992.37.739.8 1.442 1.288 2.107a19.861 19.861 0 005.995-3.03c.492-5.265-.84-9.831-3.31-13.874zM8.02 15.331c-1.182 0-2.157-1.085-2.157-2.419 0-1.334.956-2.419 2.157-2.419 1.209 0 2.176 1.094 2.157 2.419 0 1.334-.956 2.419-2.157 2.419zm7.96 0c-1.182 0-2.157-1.085-2.157-2.419 0-1.334.956-2.419 2.157-2.419 1.209 0 2.176 1.094 2.157 2.419 0 1.334-.948 2.419-2.157 2.419z"/></svg>
        Join ZINC Discord
      </a>
    </div>
  </section>

  <section class="demo-panel">
    <img src="/zinc-chat-demo.gif" alt="ZINC Chat — streaming LLM inference on AMD RDNA4 GPU" class="demo-gif" />
    <p class="demo-caption">35B parameter model running locally on a single AMD GPU — Zig + Vulkan, no ROCm, no MLX</p>
    <div class="start-links">
      <a href="/zinc/docs/getting-started">Getting Started</a>
      <a href="/zinc/docs/hardware-requirements">Hardware Requirements</a>
      <a href="/zinc/docs/running-zinc">Running ZINC</a>
      <a href="/zinc/docs">All Docs</a>
    </div>
  </section>

  <section>
    <p>Consumer GPUs have the hardware for fast LLM inference, but the software stack doesn't use it well. AMD's RDNA cards are ignored by ROCm and get generic Vulkan in llama.cpp. Apple Silicon runs MLX and llama.cpp Metal, but no engine is built from scratch around Metal's strengths. ZINC targets both platforms with hand-tuned shaders.</p>

    <p><strong>ZINC is not finished productized infrastructure yet.</strong> It is an experimental engine under active development, and the best current experience is still Linux-first, AMD-first, and CLI-first. The point of the docs is to make that path explicit instead of making you reverse-engineer it from technical specs.</p>

    <p>ZINC takes a different approach. It is an inference engine written in <strong>Zig</strong> with hand-tuned <strong>Vulkan compute shaders</strong>, built specifically for the GPU architecture these cards actually have.</p>

    <h2>Why not vLLM or llama.cpp?</h2>

    <table>
      <thead>
        <tr><th></th><th>ZINC</th><th>vLLM</th><th>llama.cpp (Vulkan)</th></tr>
      </thead>
      <tbody>
        <tr><td><strong>RDNA3/RDNA4 support</strong></td><td>First-class target</td><td>Not supported (needs ROCm)</td><td>Works, no RDNA4 tuning</td></tr>
        <tr><td><strong>Continuous batching</strong></td><td>Roadmap</td><td>Built-in</td><td>Server-bolted</td></tr>
        <tr><td><strong>Paged KV cache</strong></td><td>vLLM-style PagedAttention</td><td>Yes</td><td>No (contiguous)</td></tr>
        <tr><td><strong>KV cache compression</strong></td><td>TurboQuant roadmap / experimental path</td><td>No</td><td>No</td></tr>
        <tr><td><strong>GPU kernel tuning</strong></td><td>RDNA4 wave64, coop matrix</td><td>ROCm/CUDA only</td><td>Generic Vulkan</td></tr>
        <tr><td><strong>OpenAI API</strong></td><td>Native</td><td>Native</td><td>Via server wrapper</td></tr>
      </tbody>
    </table>

    <h2>Performance on AMD RDNA4</h2>

    <p>Current validated numbers on a clean AI PRO R9700 node with `zig build -Doptimize=ReleaseFast`. These are measured results, not the older projected target state.</p>

    <table>
      <thead>
        <tr><th>GPU</th><th>Model</th><th>Path</th><th>ZINC</th><th>llama.cpp</th></tr>
      </thead>
      <tbody>
        <tr><td><strong>AI PRO R9700</strong></td><td>Qwen3.5-35B-A3B-UD-Q4_K_XL</td><td>decode</td><td><strong>103.72 tok/s</strong></td><td>96.76 tok/s</td></tr>
        <tr><td><strong>AI PRO R9700</strong></td><td>Qwen3.6-35B-A3B-UD-Q4_K_XL</td><td>decode</td><td>99.40 tok/s</td><td>104.48 tok/s</td></tr>
        <tr><td><strong>AI PRO R9700</strong></td><td>Gemma 4 31B (dense)</td><td>decode</td><td><strong>44.53 tok/s</strong></td><td>32.17 tok/s</td></tr>
        <tr><td><strong>AI PRO R9700</strong></td><td>GPT-OSS 20B</td><td>decode</td><td>83.41 tok/s</td><td>181.72 tok/s</td></tr>
        <tr><td><strong>AI PRO R9700</strong></td><td>Qwen 3 8B (dense)</td><td>prefill</td><td><strong>115.85 tok/s</strong></td><td>84.73 tok/s</td></tr>
      </tbody>
    </table>

    <p>Median tok/s across the perf suite's runs (2026-05-02 refresh) on the RDNA4 test node with <code>zig build -Doptimize=ReleaseFast</code> and <code>RADV_PERFTEST=coop_matrix</code>. Bold rows are where ZINC currently beats llama.cpp on the same hardware. Full breakdown: <a href="/zinc/performance">/zinc/performance</a>.</p>

    <h2>Performance on Apple Silicon</h2>

    <p>Current validated Apple Silicon numbers on <strong>Mac Studio (Mac16,9)</strong> with <strong>Apple M4 Max</strong>, <strong>40-core GPU</strong>, and <strong>64 GB unified memory</strong>. Same engine, native Metal backend, <code>zig build -Doptimize=ReleaseFast</code>.</p>

    <table>
      <thead>
        <tr><th>Machine</th><th>Model</th><th>Path</th><th>ZINC</th><th>llama.cpp</th></tr>
      </thead>
      <tbody>
        <tr><td><strong>Mac Studio (M4 Max)</strong></td><td>Qwen3.5-35B-A3B-UD-Q4_K_XL</td><td>decode</td><td>46.36 tok/s</td><td>77.70 tok/s</td></tr>
        <tr><td><strong>Mac Studio (M4 Max)</strong></td><td>Qwen3.6-35B-A3B-UD-Q4_K_XL</td><td>decode</td><td>38.13 tok/s</td><td>79.88 tok/s</td></tr>
        <tr><td><strong>Mac Studio (M4 Max)</strong></td><td>Gemma 4 12B</td><td>decode</td><td>43.68 tok/s</td><td>92.17 tok/s</td></tr>
        <tr><td><strong>Mac Studio (M4 Max)</strong></td><td>Qwen 3 8B (dense)</td><td>decode</td><td>32.74 tok/s</td><td>83.67 tok/s</td></tr>
        <tr><td><strong>Mac Studio (M4 Max)</strong></td><td>GPT-OSS 20B</td><td>decode</td><td>25.98 tok/s</td><td>119.85 tok/s</td></tr>
      </tbody>
    </table>

    <p>Those Apple numbers are for the exact machine above (2026-05-02 refresh), not a generic "Apple Silicon" average. Metal decode is closing the gap on the larger A3B models; the Gemma 4 31B path is the active optimization target. Full breakdown including prefill: <a href="/zinc/performance">/zinc/performance</a>.</p>

    <h2>What ZINC does</h2>

    <p><strong>Two GPU backends, one engine.</strong> On AMD: <a href="/zinc/docs/rdna4-tuning">wave64, cooperative matrix, architecture-aware tiling</a> via Vulkan compute. On Apple Silicon: <a href="/zinc/docs/apple-metal-reference">native MSL kernels</a> with simdgroup ops, zero-copy mmap, and Metal pipeline tuning. ZINC picks the right backend at build time.</p>

    <p>The API is OpenAI-compatible: <code>POST /v1/chat/completions</code> with SSE streaming, plus a built-in chat UI with thinking mode support. Point your existing client at ZINC and it works. <a href="/zinc/docs/api">API reference</a>.</p>

    <p>Models load from GGUF files via direct memory-map — DMA to GPU VRAM on Vulkan, zero-copy <code>newBufferWithBytesNoCopy</code> on Metal. Supports Q4_K, Q5_K, Q6_K, Q8_0, and F16 quantization. Architectures: Qwen, MoE, and Mamba/Jamba hybrids.</p>

    <p>The whole thing is written in Zig (with a thin Objective-C shim for Metal). No hidden allocations, direct GPU API calls, comptime dispatch tables, single binary.</p>

    <h2>Architecture</h2>

    <div class="arch-diagram">
      <img src="/zinc-architecture.svg" alt="ZINC Architecture" width="680" />
    </div>

    <h2>Supported hardware</h2>

    <p>ZINC targets AMD GPUs via Vulkan compute and Apple Silicon via Metal. No ROCm, no MLX, no heavyweight framework.</p>

    <h3>AMD GPUs (Linux)</h3>
    <ul>
      <li><strong>RDNA4</strong>: RX 9070, RX 9070 XT, Radeon AI PRO R9700 (primary tuning target)</li>
      <li><strong>RDNA3</strong>: RX 7900 XTX, RX 7900 XT, RX 7800 XT, RX 7700 XT, RX 7600</li>
    </ul>
    <p>Any AMD GPU with Vulkan 1.3 and RADV or AMDVLK drivers should work.</p>

    <h3>Apple Silicon (macOS)</h3>
    <ul>
      <li><strong>M1 through M5</strong>: all variants (base, Pro, Max, Ultra)</li>
      <li>Current public reference box: Mac Studio (M4 Max, 40-core GPU, 64 GB unified memory)</li>
      <li>Native Metal shaders, zero-copy model loading, unified memory</li>
      <li>16 GB for 2B models, 24+ GB for 35B models</li>
    </ul>

    <p>See the full <a href="/zinc/docs/hardware-requirements">hardware requirements</a> page for details.</p>

    <hr />
    <p><a href="/zinc/docs">Documentation</a> · <a href="/zinc/docs/turboquant-spec">TurboQuant spec</a> · <a href="https://github.com/zolotukhin/zinc">GitHub</a></p>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: var(--space-xl) 0;
  }

  .logo {
    border-radius: 12px;
    margin-bottom: var(--space-md);
  }

  .hero h1 {
    font-size: 2rem;
    margin-bottom: var(--space-xs);
  }

  .tagline {
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .hero-links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: var(--space-sm);
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.88rem;
    color: var(--color-text-muted);
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .hero-link:hover {
    text-decoration: none;
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .hero-link-discord {
    border-color: color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
    color: var(--color-accent);
  }

  .hero-link-benchmarks {
    border-color: color-mix(in srgb, var(--color-accent) 20%, var(--color-border));
  }

  .hero-link-discord:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .btn-outline:hover {
    border-color: var(--color-accent);
  }

  .demo-panel {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .demo-gif {
    width: 100%;
    max-width: 720px;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    margin-bottom: var(--space-sm);
  }

  .demo-caption {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .start-panel {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .start-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    justify-content: center;
  }

  .start-links a {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text);
  }

  .start-links a:hover {
    text-decoration: none;
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .arch-diagram {
    text-align: center;
    margin: var(--space-lg) 0;
  }

  .arch-diagram img {
    max-width: 100%;
    height: auto;
  }
</style>
