<script>
  const LABELS = {
    bash: 'Terminal',
    sh: 'Terminal',
    shell: 'Terminal',
    zsh: 'Terminal',
    console: 'Terminal',
    zig: 'Zig',
    glsl: 'GLSL',
    json: 'JSON',
    js: 'JavaScript',
    javascript: 'JavaScript',
    ts: 'TypeScript',
    typescript: 'TypeScript',
    yaml: 'YAML',
    yml: 'YAML',
    text: 'Text',
    plaintext: 'Text',
  };

  function inferLanguage(pre, code) {
    const candidates = [
      pre.getAttribute('data-language'),
      code?.getAttribute('data-language'),
      ...Array.from(pre.classList),
      ...Array.from(code?.classList ?? []),
    ].filter(Boolean);

    for (const candidate of candidates) {
      const match = String(candidate).match(/language-([a-z0-9_-]+)/i);
      if (match) return match[1].toLowerCase();
      if (LABELS[String(candidate).toLowerCase()]) return String(candidate).toLowerCase();
    }

    return '';
  }

  function inferLabelFromText(text) {
    const trimmed = text.trim();
    if (!trimmed) return 'Code';
    if (trimmed.startsWith('{') || trimmed.startsWith('[')) return 'JSON';
    if (/^(sudo|git|cd |zig |curl |export |\.\/|vulkaninfo|glslc|lspci|dot )/m.test(trimmed)) return 'Terminal';
    if (/^info\([^)]+\):/m.test(trimmed)) return 'Terminal';
    return 'Code';
  }

  function enhanceCodeBlocks() {
    const pres = document.querySelectorAll('pre');
    for (const pre of pres) {
      if (pre.dataset.codeEnhanced === 'true') continue;
      if (pre.closest('.code-shell')) continue;

      const code = pre.querySelector('code');
      const rawText = code?.textContent?.replace(/\s+$/, '') ?? pre.textContent?.replace(/\s+$/, '') ?? '';
      if (!rawText) continue;

      const language = inferLanguage(pre, code);
      const label = pre.dataset.codeLabel || LABELS[language] || inferLabelFromText(rawText);
      const isTerminal = label === 'Terminal';

      const wrapper = document.createElement('div');
      wrapper.className = `code-shell${isTerminal ? ' code-shell--terminal' : ''}`;

      const header = document.createElement('div');
      header.className = 'code-shell__header';

      const headerLeft = document.createElement('div');
      headerLeft.className = 'code-shell__header-left';

      if (isTerminal) {
        const dots = document.createElement('span');
        dots.className = 'code-shell__dots';
        dots.innerHTML = '<i></i><i></i><i></i>';
        headerLeft.appendChild(dots);
      }

      const title = document.createElement('span');
      title.className = 'code-shell__label';
      title.textContent = label;
      headerLeft.appendChild(title);

      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'code-shell__copy';
      button.setAttribute('aria-label', `Copy ${label} block`);
      button.textContent = 'Copy';
      button.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(rawText);
          const original = button.textContent;
          button.textContent = 'Copied';
          button.classList.add('is-copied');
          window.setTimeout(() => {
            button.textContent = original ?? 'Copy';
            button.classList.remove('is-copied');
          }, 1400);
        } catch (error) {
          console.warn('Clipboard copy failed', error);
        }
      });

      header.append(headerLeft, button);
      pre.dataset.codeEnhanced = 'true';

      const parent = pre.parentNode;
      if (!parent) continue;
      parent.insertBefore(wrapper, pre);
      wrapper.append(header, pre);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', enhanceCodeBlocks, { once: true });
  } else {
    enhanceCodeBlocks();
  }
</script>

