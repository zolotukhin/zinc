---
interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonicalUrl?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageType?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  publishedDate?: string;
  tags?: string[];
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  keywords,
  canonicalUrl = Astro.url.href,
  ogType = 'website',
  ogImage = '/og-image-v2.png',
  ogImageAlt,
  ogImageType,
  ogImageWidth,
  ogImageHeight,
  publishedDate,
  tags,
  jsonLd,
} = Astro.props;

const fullTitle = title === 'Stepan Zolotukhin'
  ? 'Stepan Zolotukhin — zolotukhin.ai'
  : title.includes('zolotukhin') ? title : `${title} — zolotukhin.ai`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://zolotukhin.ai';
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const defaultOgImagePath = '/og-image-v2.png';
const usingDefaultOgImage = ogImage === defaultOgImagePath || ogImageUrl === `${siteUrl}${defaultOgImagePath}`;
const resolvedOgImageAlt = ogImageAlt ?? `${title} — zolotukhin.ai preview image`;
const resolvedOgImageType = ogImageType
  ?? (ogImageUrl.endsWith('.png') ? 'image/png'
    : (ogImageUrl.endsWith('.jpg') || ogImageUrl.endsWith('.jpeg')) ? 'image/jpeg'
    : ogImageUrl.endsWith('.webp') ? 'image/webp'
    : undefined);
const resolvedOgImageWidth = ogImageWidth ?? (usingDefaultOgImage ? 768 : undefined);
const resolvedOgImageHeight = ogImageHeight ?? (usingDefaultOgImage ? 442 : undefined);
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
{keywords && <meta name="keywords" content={keywords} />}
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={ogType} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:secure_url" content={ogImageUrl} />
{resolvedOgImageType && <meta property="og:image:type" content={resolvedOgImageType} />}
{resolvedOgImageWidth && <meta property="og:image:width" content={String(resolvedOgImageWidth)} />}
{resolvedOgImageHeight && <meta property="og:image:height" content={String(resolvedOgImageHeight)} />}
<meta property="og:image:alt" content={resolvedOgImageAlt} />
<meta property="og:site_name" content="zolotukhin.ai" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@zolotukhin_ai" />
<meta name="twitter:creator" content="@zolotukhin_ai" />
<meta name="twitter:url" content={canonicalUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:src" content={ogImageUrl} />
<meta name="twitter:image:alt" content={resolvedOgImageAlt} />

{publishedDate && <meta property="article:published_time" content={publishedDate} />}
{tags && tags.map(tag => <meta property="article:tag" content={tag} />)}

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title="zolotukhin.ai" href={`${siteUrl}/feed.xml`} />
<link rel="alternate" type="text/plain" title="zolotukhin.ai llms index" href={`${siteUrl}/llms.txt`} />

{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
