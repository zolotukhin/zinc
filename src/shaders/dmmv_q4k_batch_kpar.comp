#version 460
// ZINC — Q4_K batched DMMV, K-parallel wave64 reduction.
//
// One workgroup per output row. 64 threads cooperate on K via the same
// 16-threads-per-block pattern as dmmv_q4k_moe_kpar / dmmv_q4k.comp —
// each thread dequantizes a 4-element stripe across 4 Q4_K blocks per
// outer iteration, multiplies against all `num_cols` input vectors, and
// accumulates into per-column register sums. A single subgroupAdd per
// column at the end reduces across all 64 lanes.
//
// Rationale: the existing dmmv_q4k_batch.comp assigns one thread per
// output row and walks the entire K dimension serially. That gives up
// the 64-way per-row parallelism the per-token kpar path relies on,
// and on gfx1201 the resulting serial compute path is slower than the
// 32 separate kpar dispatches it was meant to replace even at
// num_cols = 32. Mirroring kpar's thread layout puts this variant
// inside the same compute envelope as the proven per-token kernel
// while still reading each weight block exactly once per batch chunk.
//
// Dispatch: (M, 1, 1). gl_WorkGroupID.x selects the row; local threads
// share the K reduction. Binding layout matches dmmv_q4k_batch.comp
// exactly (A, X_batch, Y_batch) so recordBatchDispatchPush can toggle
// between the two at runtime.

#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64) in;

// MAX_COLS trades off register pressure vs number of prefill chunks.
// Measured on Qwen3-8B Q4_K_M on R9700 (105-token prefill median of 5):
//   MAX_COLS=16 → 155 tok/s   (7 chunks — extra weight-read passes dominate)
//   MAX_COLS=32 → 173 tok/s   (4 chunks — sweet spot)
//   MAX_COLS=64 → 153 tok/s   (2 chunks but VGPR spill / occupancy loss)
// Keep at 32.
const uint MAX_COLS = 32u;
const uint Q4K_BLOCK_U32 = 36u;  // 144 bytes / 4
const uint Q4K_BLOCK_SIZE = 256u;

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;
    uint a_offset;
    uint x_offset;
    uint y_offset;
    uint num_cols;
};

layout(set = 0, binding = 0) readonly buffer MatrixA { uint a_u32[]; };
layout(set = 0, binding = 1) readonly buffer MatrixX { vec4 x_v4[]; };
layout(set = 0, binding = 2) writeonly buffer MatrixY { float y_data[]; };

vec4 unpack_nibbles_lo(uint v) {
    return vec4(float(v & 0xFu), float((v >> 8) & 0xFu),
                float((v >> 16) & 0xFu), float((v >> 24) & 0xFu));
}
vec4 unpack_nibbles_hi(uint v) {
    return vec4(float((v >> 4) & 0xFu), float((v >> 12) & 0xFu),
                float((v >> 20) & 0xFu), float((v >> 28) & 0xFu));
}

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint row = gl_WorkGroupID.x;
    if (row >= M) return;

    const uint THREADS_PER_BLOCK = 16u;
    const uint it_size = 64u / THREADS_PER_BLOCK;  // = 4 blocks in parallel
    uint itid = tid % THREADS_PER_BLOCK;
    uint ix   = tid / THREADS_PER_BLOCK;

    // Position within the 256-element superblock — matches dmmv_q4k_moe_kpar
    // so the weight decode bit layout is identical to the kernel everybody
    // already trusts.
    uint il = itid / 4u;
    uint ir = itid % 4u;
    uint v_im = il / 2u;
    uint v_in = il % 2u;
    uint l0 = 4u * (2u * ir + v_in);
    uint q_offset_in_half = 32u * v_im + l0;
    uint y_offset_local   = 64u * v_im + l0;

    uint blocks_per_row = K / Q4K_BLOCK_SIZE;
    uint row_u32 = a_offset / 4u + row * blocks_per_row * Q4K_BLOCK_U32;

    float sums[MAX_COLS];
    for (uint c = 0u; c < num_cols; c++) sums[c] = 0.0;

    // Per-block column bases in vec4 indexing: column c's X vector starts at
    // x_offset/16 + c * (K/4) floats-as-vec4.
    uint x_col_stride_v4 = K / 4u;
    uint x_global_base_v4 = x_offset / 16u;

    for (uint i = ix; i < blocks_per_row; i += it_size) {
        uint blk_u32 = row_u32 + i * Q4K_BLOCK_U32;

        uint d_dmin = a_u32[blk_u32];
        float d_val    = unpackHalf2x16(d_dmin & 0xFFFFu).x;
        float dmin_val = unpackHalf2x16(d_dmin >> 16).x;

        uint sc0 = a_u32[blk_u32 + 1u];
        uint sc1 = a_u32[blk_u32 + 2u];
        uint sc2 = a_u32[blk_u32 + 3u];

        uint qs_u32_0 = a_u32[blk_u32 + 4u + q_offset_in_half / 4u];
        uint qs_u32_1 = a_u32[blk_u32 + 4u + q_offset_in_half / 4u + 16u];

        vec4 q0_lo = unpack_nibbles_lo(qs_u32_0);
        vec4 q0_hi = unpack_nibbles_hi(qs_u32_0);
        vec4 q1_lo = unpack_nibbles_lo(qs_u32_1);
        vec4 q1_hi = unpack_nibbles_hi(qs_u32_1);

        uint bytes[12];
        bytes[0] = sc0 & 0xFFu; bytes[1] = (sc0>>8)&0xFFu; bytes[2] = (sc0>>16)&0xFFu; bytes[3] = (sc0>>24)&0xFFu;
        bytes[4] = sc1 & 0xFFu; bytes[5] = (sc1>>8)&0xFFu; bytes[6] = (sc1>>16)&0xFFu; bytes[7] = (sc1>>24)&0xFFu;
        bytes[8] = sc2 & 0xFFu; bytes[9] = (sc2>>8)&0xFFu; bytes[10] = (sc2>>16)&0xFFu; bytes[11] = (sc2>>24)&0xFFu;

        uint sb_a = 2u * v_im;
        uint sb_b = 2u * v_im + 1u;
        uint sb_c = 2u * v_im + 4u;
        uint sb_d = 2u * v_im + 5u;

        float sc_a, mn_a, sc_b, mn_b, sc_c, mn_c, sc_d, mn_d;
        if (sb_a < 4u) { sc_a = float(bytes[sb_a] & 63u); mn_a = float(bytes[sb_a+4u] & 63u); }
        else { sc_a = float((bytes[sb_a+4u]&0xFu)|((bytes[sb_a-4u]>>6)<<4)); mn_a = float(((bytes[sb_a+4u]>>4)&0xFu)|((bytes[sb_a]>>6)<<4)); }
        if (sb_b < 4u) { sc_b = float(bytes[sb_b] & 63u); mn_b = float(bytes[sb_b+4u] & 63u); }
        else { sc_b = float((bytes[sb_b+4u]&0xFu)|((bytes[sb_b-4u]>>6)<<4)); mn_b = float(((bytes[sb_b+4u]>>4)&0xFu)|((bytes[sb_b]>>6)<<4)); }
        if (sb_c < 4u) { sc_c = float(bytes[sb_c] & 63u); mn_c = float(bytes[sb_c+4u] & 63u); }
        else { sc_c = float((bytes[sb_c+4u]&0xFu)|((bytes[sb_c-4u]>>6)<<4)); mn_c = float(((bytes[sb_c+4u]>>4)&0xFu)|((bytes[sb_c]>>6)<<4)); }
        if (sb_d < 4u) { sc_d = float(bytes[sb_d] & 63u); mn_d = float(bytes[sb_d+4u] & 63u); }
        else { sc_d = float((bytes[sb_d+4u]&0xFu)|((bytes[sb_d-4u]>>6)<<4)); mn_d = float(((bytes[sb_d+4u]>>4)&0xFu)|((bytes[sb_d]>>6)<<4)); }

        float factor0 = d_val * sc_a; float bias0 = dmin_val * mn_a;
        float factor1 = d_val * sc_b; float bias1 = dmin_val * mn_b;
        float factor2 = d_val * sc_c; float bias2 = dmin_val * mn_c;
        float factor3 = d_val * sc_d; float bias3 = dmin_val * mn_d;

        // Walk all columns for this thread's 16-element stripe of block i.
        uint b_idx  = (i * 256u + y_offset_local) / 4u;
        uint b_idx2 = (i * 256u + y_offset_local + 128u) / 4u;

        for (uint c = 0u; c < num_cols; c++) {
            uint col_base_v4 = x_global_base_v4 + c * x_col_stride_v4;
            vec4 by0 = x_v4[col_base_v4 + b_idx];
            vec4 by1 = x_v4[col_base_v4 + b_idx + 8u];
            vec4 by2 = x_v4[col_base_v4 + b_idx2];
            vec4 by3 = x_v4[col_base_v4 + b_idx2 + 8u];

            float partial = dot(vec4(factor0) * q0_lo - vec4(bias0), by0)
                          + dot(vec4(factor1) * q0_hi - vec4(bias1), by1)
                          + dot(vec4(factor2) * q1_lo - vec4(bias2), by2)
                          + dot(vec4(factor3) * q1_hi - vec4(bias3), by3);
            sums[c] += partial;
        }
    }

    // wave64 subgroupAdd across all 64 lanes, one column at a time.
    for (uint c = 0u; c < num_cols; c++) {
        float reduced = subgroupAdd(sums[c]);
        if (tid == 0u) {
            y_data[y_offset / 4u + c * M + row] = reduced;
        }
    }
}
