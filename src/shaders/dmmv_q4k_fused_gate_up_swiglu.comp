#version 460
// ZINC — Q4_K dense fused gate+up DMMV with inline SwiGLU activation.
//
// Fuses the three dense FFN front-end ops that run sequentially on the
// per-token decode hot path (Qwen 3 dense and similar):
//   gate = W_gate · x          (DMMV)
//   up   = W_up   · x          (DMMV)
//   swiglu[r] = silu(gate[r]) * up[r]
// into ONE dispatch. Eliminates the gate_buf and up_buf intermediates
// entirely from the dense FFN datapath, saves one vkCmdDispatch (the
// SwiGLU activation), and saves one global compute barrier (the
// gate+up → swiglu barrier).
//
// Mirrors dmmv_q4k_fused_gate_up_moe.comp's per-block dequant inner
// loop exactly. The only structural changes are:
//   1. No expert routing (no gl_WorkGroupID.y, no routing buffer).
//   2. Single output binding `swiglu` instead of separate y_gate/y_up.
//   3. After subgroupAdd, lane 0 computes silu(gate) * up inline and
//      writes one float per row to swiglu[].
//
// The silu fusion is bit-equivalent up to fp32 reordering — same
// silu definition `g / (1 + exp(-g))` as swiglu.comp, applied to the
// same scalar `sum_gate` value the unfused path would have written
// to gate_buf.
//
// Dispatch: ((M+1)/2, 1, 1).
//   gl_WorkGroupID.x → row pair within the FFN inter_dim
//
// Bindings:
//   0 W_gate   (Q4_K, M*K row-major, uint32-indexed)
//   1 W_up     (Q4_K, same shape as W_gate)
//   2 X        (input vector, vec4 stream — ffn_norm_buf)
//   3 swiglu   (output, f32, M elements — silu(gate) * up)
//
// Push: dmmv DmmvPushConstants (M, K, a_offset, x_offset, y_offset,
// acc_mode). a_offset/x_offset/y_offset all in BYTES; acc_mode is
// ignored (output is always overwritten — no accumulator on this fused
// path). The same push struct is used so the dispatch helper matches
// pipeline_q4k.

#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64) in;

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;
    uint a_offset;
    uint x_offset;
    uint y_offset;
    uint acc_mode;  // ignored; swiglu always overwrites
};

layout(set = 0, binding = 0) readonly buffer MatrixAGate { uint a_gate_u32[]; };
layout(set = 0, binding = 1) readonly buffer MatrixAUp   { uint a_up_u32[];   };
layout(set = 0, binding = 2) readonly buffer VectorX     { vec4 x_v4[];       };
layout(set = 0, binding = 3) writeonly buffer Swiglu     { float swiglu[];    };

const uint NUM_ROWS = 2u;
const uint Q4K_BLOCK_U32 = 36u;  // 144 bytes / 4

vec4 unpack_nibbles_lo(uint v) {
    return vec4(float(v & 0xFu), float((v >> 8) & 0xFu),
                float((v >> 16) & 0xFu), float((v >> 24) & 0xFu));
}
vec4 unpack_nibbles_hi(uint v) {
    return vec4(float((v >> 4) & 0xFu), float((v >> 12) & 0xFu),
                float((v >> 20) & 0xFu), float((v >> 28) & 0xFu));
}

// v_im-uniform straight-line scale decode. Matches dmmv_q4k_moe_kpar.comp's
// shift+mask form: shifting sc{0,1,2} right by 16*v_im selects the byte
// pair this thread needs without dynamic indexing or branching, replacing
// the bytes[12] array + 4 if/else conditionals. Bit-equivalent to the
// original decode_sb function for v_im ∈ {0,1}.
void decode_scales(uint sc0, uint sc1, uint sc2, uint shift,
                   out float sc_a, out float mn_a,
                   out float sc_b, out float mn_b,
                   out float sc_c, out float mn_c,
                   out float sc_d, out float mn_d) {
    uint sc0_v = sc0 >> shift;
    uint sc1_v = sc1 >> shift;
    uint sc2_v = sc2 >> shift;

    sc_a = float(sc0_v & 0x3Fu);
    mn_a = float(sc1_v & 0x3Fu);
    sc_b = float((sc0_v >> 8u) & 0x3Fu);
    mn_b = float((sc1_v >> 8u) & 0x3Fu);
    sc_c = float((sc2_v & 0xFu) | ((sc0_v & 0xC0u) >> 2u));
    mn_c = float(((sc2_v & 0xF0u) >> 4u) | ((sc1_v & 0xC0u) >> 2u));
    sc_d = float(((sc2_v >> 8u) & 0xFu) | (((sc0_v >> 8u) & 0xC0u) >> 2u));
    mn_d = float((((sc2_v >> 8u) & 0xF0u) >> 4u) | (((sc1_v >> 8u) & 0xC0u) >> 2u));
}

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint wg_id = gl_WorkGroupID.x;

    const uint THREADS_PER_BLOCK = 16u;
    const uint it_size = 64u / THREADS_PER_BLOCK;  // = 4
    uint itid = tid % THREADS_PER_BLOCK;
    uint ix = tid / THREADS_PER_BLOCK;

    uint il = itid / 4u;
    uint ir = itid % 4u;
    uint v_im = il / 2u;
    uint v_in = il % 2u;
    uint l0 = 4u * (2u * ir + v_in);
    uint q_offset_in_half = 32u * v_im + l0;
    uint y_offset_local = 64u * v_im + l0;

    uint x_base_v4 = x_offset / 16u;
    uint y_base = y_offset / 4u;
    uint a_base_u32 = a_offset / 4u;
    uint blocks_per_row = K / 256u;

    // v_im-uniform shift hoisted out of the inner per-block loop; v_im is
    // loop-invariant (a function of tid only) so it lifts cleanly.
    uint shift = v_im * 16u;

    for (uint r = 0u; r < NUM_ROWS; r++) {
        uint row = wg_id * NUM_ROWS + r;
        if (row >= M) break;

        uint row_u32 = a_base_u32 + row * blocks_per_row * Q4K_BLOCK_U32;
        float sum_gate = 0.0;
        float sum_up = 0.0;

        for (uint i = ix; i < blocks_per_row; i += it_size) {
            uint blk_u32 = row_u32 + i * Q4K_BLOCK_U32;

            // ── Load the B-vector tile once; both projections reuse it.
            uint b_idx = (i * 256u + y_offset_local) / 4u;
            vec4 by0 = x_v4[x_base_v4 + b_idx];
            vec4 by1 = x_v4[x_base_v4 + b_idx + 8u];
            uint b_idx2 = (i * 256u + y_offset_local + 128u) / 4u;
            vec4 by2 = x_v4[x_base_v4 + b_idx2];
            vec4 by3 = x_v4[x_base_v4 + b_idx2 + 8u];

            // ── Gate block.
            {
                uint d_dmin = a_gate_u32[blk_u32];
                float d_val = unpackHalf2x16(d_dmin & 0xFFFFu).x;
                float dmin_val = unpackHalf2x16(d_dmin >> 16).x;

                uint sc0 = a_gate_u32[blk_u32 + 1u];
                uint sc1 = a_gate_u32[blk_u32 + 2u];
                uint sc2 = a_gate_u32[blk_u32 + 3u];

                uint qs_u32_0 = a_gate_u32[blk_u32 + 4u + q_offset_in_half / 4u];
                uint qs_u32_1 = a_gate_u32[blk_u32 + 4u + q_offset_in_half / 4u + 16u];

                vec4 q0_lo = unpack_nibbles_lo(qs_u32_0);
                vec4 q0_hi = unpack_nibbles_hi(qs_u32_0);
                vec4 q1_lo = unpack_nibbles_lo(qs_u32_1);
                vec4 q1_hi = unpack_nibbles_hi(qs_u32_1);

                float sc_a, mn_a, sc_b, mn_b, sc_c, mn_c, sc_d, mn_d;
                decode_scales(sc0, sc1, sc2, shift,
                              sc_a, mn_a, sc_b, mn_b,
                              sc_c, mn_c, sc_d, mn_d);

                float f0 = d_val * sc_a, b0 = dmin_val * mn_a;
                float f1 = d_val * sc_b, b1 = dmin_val * mn_b;
                float f2 = d_val * sc_c, b2 = dmin_val * mn_c;
                float f3 = d_val * sc_d, b3 = dmin_val * mn_d;

                sum_gate += dot(vec4(f0) * q0_lo - vec4(b0), by0);
                sum_gate += dot(vec4(f1) * q0_hi - vec4(b1), by1);
                sum_gate += dot(vec4(f2) * q1_lo - vec4(b2), by2);
                sum_gate += dot(vec4(f3) * q1_hi - vec4(b3), by3);
            }

            // ── Up block (same row + block index, different weight stream).
            {
                uint d_dmin = a_up_u32[blk_u32];
                float d_val = unpackHalf2x16(d_dmin & 0xFFFFu).x;
                float dmin_val = unpackHalf2x16(d_dmin >> 16).x;

                uint sc0 = a_up_u32[blk_u32 + 1u];
                uint sc1 = a_up_u32[blk_u32 + 2u];
                uint sc2 = a_up_u32[blk_u32 + 3u];

                uint qs_u32_0 = a_up_u32[blk_u32 + 4u + q_offset_in_half / 4u];
                uint qs_u32_1 = a_up_u32[blk_u32 + 4u + q_offset_in_half / 4u + 16u];

                vec4 q0_lo = unpack_nibbles_lo(qs_u32_0);
                vec4 q0_hi = unpack_nibbles_hi(qs_u32_0);
                vec4 q1_lo = unpack_nibbles_lo(qs_u32_1);
                vec4 q1_hi = unpack_nibbles_hi(qs_u32_1);

                float sc_a, mn_a, sc_b, mn_b, sc_c, mn_c, sc_d, mn_d;
                decode_scales(sc0, sc1, sc2, shift,
                              sc_a, mn_a, sc_b, mn_b,
                              sc_c, mn_c, sc_d, mn_d);

                float f0 = d_val * sc_a, b0 = dmin_val * mn_a;
                float f1 = d_val * sc_b, b1 = dmin_val * mn_b;
                float f2 = d_val * sc_c, b2 = dmin_val * mn_c;
                float f3 = d_val * sc_d, b3 = dmin_val * mn_d;

                sum_up += dot(vec4(f0) * q0_lo - vec4(b0), by0);
                sum_up += dot(vec4(f1) * q0_hi - vec4(b1), by1);
                sum_up += dot(vec4(f2) * q1_lo - vec4(b2), by2);
                sum_up += dot(vec4(f3) * q1_hi - vec4(b3), by3);
            }
        }

        sum_gate = subgroupAdd(sum_gate);
        sum_up = subgroupAdd(sum_up);
        if (tid == 0u) {
            float silu_g = sum_gate / (1.0 + exp(-sum_gate));
            swiglu[y_base + row] = silu_g * sum_up;
        }
    }
}
