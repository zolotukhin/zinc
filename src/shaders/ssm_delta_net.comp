#version 460
// ZINC — SSM delta-net recurrent state update
// Performs the delta-net autoregressive state update for Mamba/SSM layers,
// replacing the CPU-side computation with a fully GPU-resident kernel.
// Optimized for AMD RDNA4 (wave64): workgroup = 64 threads = 1 full wave.
//
// Each workgroup handles one 4-row tile of one head, with 16 threads per row.
// Dispatch shape: dt_rank × ceil(head_v_dim / 4) × 1.
// State per head is head_v_dim × head_v_dim (128×128 = 16384 floats).
// With 64 threads = 4 rows × 16 threads/row, ALL threads are active during
// state update. Each thread handles 128/16=8 strided columns, then
// subgroupShuffleXor (xor 1,2,4,8) reduces partial sums across 16 threads.
// 1024 workgroups (16 per CU) — wider work for better latency hiding on
// RDNA4 and 2× cache line efficiency vs the prior 8-thread mapping
// (each row's per-iter access goes from 32 bytes (25% line) to 64 bytes
// (50% line)). Halved per-thread reg_state[8] vs [16] cuts VGPR
// pressure, lifting wave-occupancy on each SIMD32.
//
// Algorithm per head h:
//   1. Extract Q, K, V slices from conv_out
//      conv_out layout: [Q(n_group*d_state), K(n_group*d_state), V(d_inner)]
//   2. L2 normalize Q and K per group, scale Q by 1/sqrt(d_state)
//   3. Compute gate = exp(softplus(alpha + dt_bias) * ssm_a), beta_val = sigmoid(beta)
//   4. Decay state: s *= gate
//   5. For each row: sk = dot(s[row], k), d = beta_val * (v[row] - sk)
//      then s[row][col] += k[col] * d
//   6. Readout: output[h*head_v_dim + row] = dot(s[row], q)
//
// Dispatch: dt_rank × ceil(head_v_dim / 64) × 1 workgroups

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_shuffle : require
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_shader_16bit_storage : require

layout(local_size_x = 64) in;

// conv_out: output of conv1d+SiLU, layout [Q(n_group*d_state), K(n_group*d_state), V(d_inner)]
layout(set = 0, binding = 0) readonly buffer ConvOut {
    float conv_out[];
};

// dt_bias: per-head bias for DT (dt_rank floats)
layout(set = 0, binding = 1) readonly buffer DtBiasF32 {
    float dt_bias_f32[];
};
layout(set = 0, binding = 1) readonly buffer DtBiasF16 {
    float16_t dt_bias_f16[];
};

// alpha: per-head DT projection (dt_rank floats)
layout(set = 0, binding = 2) readonly buffer Alpha {
    float alpha[];
};

// beta: per-head beta projection (dt_rank floats)
layout(set = 0, binding = 3) readonly buffer Beta {
    float beta[];
};

// ssm_a weights: decay factors per head (dt_rank floats, may be f16)
layout(set = 0, binding = 4) readonly buffer SsmAF32 {
    float ssm_a_f32[];
};
layout(set = 0, binding = 4) readonly buffer SsmAF16 {
    float16_t ssm_a_f16[];
};

// Persistent recurrent state: dt_rank * head_v_dim * head_v_dim floats, read+write
layout(set = 0, binding = 5) buffer State {
    float state[];
};

// Output: d_inner floats — delta-net readout
layout(set = 0, binding = 6) writeonly buffer Output {
    float out_data[];
};

layout(push_constant) uniform PushConstants {
    uint d_inner;       // total inner dimension (dt_rank * head_v_dim)
    uint dt_rank;       // number of heads
    uint head_v_dim;    // per-head value dimension (d_inner / dt_rank)
    uint d_state;       // state dimension per group (for Q/K)
    uint n_group;       // number of Q/K groups
    uint ssm_a_is_f16;  // 1 if ssm_a stored as f16, 0 if f32
    uint dt_bias_is_f16; // 1 if dt_bias stored as f16, 0 if f32
    uint has_dt_bias;    // 1 if dt_bias tensor exists, 0 otherwise
    uint has_ssm_a;      // 1 if ssm_a tensor exists, 0 otherwise
};

// Shared memory for Q and K vectors (up to 128 elements each)
shared float s_q[128];
shared float s_k[128];
// Shared scalar values broadcast from thread 0
shared float s_gate;
shared float s_beta_val;
shared float s_reduce[64];
shared float s_reduce_scalar;

void main() {
    uint h = gl_WorkGroupID.x;           // head index
    uint row_block = gl_WorkGroupID.y;   // 64-row tile index within the head
    uint tid = gl_LocalInvocationID.x;   // 0..63

    if (h >= dt_rank) return;

    uint qk_dim = d_state * n_group;
    uint k_len = min(head_v_dim, d_state);
    uint rows_per_tile = 4u;
    uint row = row_block * rows_per_tile + (tid / 16u);

    // --- Step 1: Load Q and K into shared memory ---
    // conv_out layout: [Q(qk_dim), K(qk_dim), V(d_inner)]
    // Q and K are grouped: group index for this head
    uint k_hi = (n_group == dt_rank) ? h : (h % n_group);
    uint q_offset = k_hi * d_state;
    uint k_offset = qk_dim + k_hi * d_state;
    uint v_offset = 2 * qk_dim + h * head_v_dim;

    // Load the active Q/K slice. Elements beyond k_len are never read.
    for (uint i = tid; i < k_len; i += 64) {
        s_q[i] = conv_out[q_offset + i];
    }
    for (uint i = tid; i < k_len; i += 64) {
        s_k[i] = conv_out[k_offset + i];
    }
    barrier();

    // --- Step 2: L2 normalize Q and K, scale Q by 1/sqrt(d_state) ---
    // L2 normalize Q
    {
        float partial = 0.0;
        for (uint i = tid; i < k_len; i += 64) {
            partial += s_q[i] * s_q[i];
        }
        partial = subgroupAdd(partial);
        if (gl_NumSubgroups > 1u) {
            if (gl_SubgroupInvocationID == 0u) {
                s_reduce[gl_SubgroupID] = partial;
            }
            barrier();
            if (tid == 0u) {
                float merged = 0.0;
                for (uint sg = 0u; sg < gl_NumSubgroups; sg++) {
                    merged += s_reduce[sg];
                }
                s_reduce_scalar = merged;
            }
            barrier();
            partial = s_reduce_scalar;
        }
        float inv_norm = inversesqrt(max(partial, 1e-12));
        float q_scale = inv_norm / sqrt(float(d_state));
        for (uint i = tid; i < k_len; i += 64) {
            s_q[i] *= q_scale;
        }
    }
    barrier();

    // L2 normalize K
    {
        float partial = 0.0;
        for (uint i = tid; i < k_len; i += 64) {
            partial += s_k[i] * s_k[i];
        }
        partial = subgroupAdd(partial);
        if (gl_NumSubgroups > 1u) {
            if (gl_SubgroupInvocationID == 0u) {
                s_reduce[gl_SubgroupID] = partial;
            }
            barrier();
            if (tid == 0u) {
                float merged = 0.0;
                for (uint sg = 0u; sg < gl_NumSubgroups; sg++) {
                    merged += s_reduce[sg];
                }
                s_reduce_scalar = merged;
            }
            barrier();
            partial = s_reduce_scalar;
        }
        float inv_norm = inversesqrt(max(partial, 1e-12));
        for (uint i = tid; i < k_len; i += 64) {
            s_k[i] *= inv_norm;
        }
    }
    barrier();

    // --- Step 3: Compute gate and beta_val (single thread, broadcast via shared) ---
    if (tid == 0) {
        float a = alpha[h];
        if (has_dt_bias != 0) {
            if (dt_bias_is_f16 != 0) {
                a += float(dt_bias_f16[h]);
            } else {
                a += dt_bias_f32[h];
            }
        }
        // softplus: log(1 + exp(a))
        float sp = log(1.0 + exp(a));
        float gate_val;
        if (has_ssm_a != 0) {
            float ssm_a_val;
            if (ssm_a_is_f16 != 0) {
                ssm_a_val = float(ssm_a_f16[h]);
            } else {
                ssm_a_val = ssm_a_f32[h];
            }
            gate_val = sp * ssm_a_val;
        } else {
            gate_val = -sp;
        }
        s_gate = exp(gate_val);
        // sigmoid(beta)
        s_beta_val = 1.0 / (1.0 + exp(-beta[h]));
    }
    barrier();

    // --- Steps 4-6: State update and readout (16 threads per row) ---
    // Thread mapping: tid = row_in_tile * 16 + col_thread
    const uint THREADS_PER_ROW = 16u;
    uint row_in_tile = tid / THREADS_PER_ROW;  // 0..3
    uint col_thread = tid % THREADS_PER_ROW;   // 0..15
    row = row_block * rows_per_tile + row_in_tile;

    if (row_in_tile >= rows_per_tile || row >= head_v_dim) return;

    float g_val = s_gate;
    float b_val = s_beta_val;
    float v_val = conv_out[v_offset + row];

    // State layout: state[h * head_v_dim * head_v_dim + row * head_v_dim + col]
    uint s_base = h * head_v_dim * head_v_dim;
    uint row_base = s_base + row * head_v_dim;

    // Register-cached state: read each col once, hold decayed value across
    // the sk reduction, then write back updated value at the end. Cuts the
    // 4 separate passes (decay-write / dot-read / update-rw / readout-read)
    // down to one read + one write per col. Bit-equivalent to the original
    // because all multiplications and additions execute in the same order;
    // only the storage location of the intermediate state value changes
    // (register vs DRAM/L2).
    //
    // MAX_COLS_PER_THREAD = 8 covers head_v_dim ≤ 128 (Qwen 3.5/3.6
    // mamba-2: head_v_dim = d_inner / dt_rank = 4096 / 32 = 128). Matches
    // the existing s_q[128] / s_k[128] shared-mem upper bound; head_v_dim
    // larger than 128 has never been a supported configuration here.
    // Halved from 16 → 8 by widening THREADS_PER_ROW from 8 → 16, which
    // reduces VGPR pressure and lifts wave-occupancy.
    const uint MAX_COLS_PER_THREAD = 8u;
    float reg_state[MAX_COLS_PER_THREAD];

    // Phase 1: Decay state into register cache and accumulate sk.
    float sk = 0.0;
    for (uint i = 0u; i < MAX_COLS_PER_THREAD; i++) {
        uint col = col_thread + i * THREADS_PER_ROW;
        if (col >= head_v_dim) break;
        float s = state[row_base + col] * g_val;
        reg_state[i] = s;
        if (col < k_len) {
            sk += s * s_k[col];
        }
    }

    // Reduce sk across the 16 threads owning this row. xor 8 stays within
    // each 16-lane group of wave64 (lanes 0-15, 16-31, 32-47, 48-63), so
    // the partial sums never cross into a different row's lane set.
    sk += subgroupShuffleXor(sk, 1u);
    sk += subgroupShuffleXor(sk, 2u);
    sk += subgroupShuffleXor(sk, 4u);
    sk += subgroupShuffleXor(sk, 8u);

    // d = beta * (v[row] - sk)
    float d_val = b_val * (v_val - sk);

    // Phase 2: Apply the rank-1 update from the cached state, write back,
    // and accumulate the readout dot. Cols outside [0, k_len) only get the
    // decayed value written back (no rank-1 update, no readout contribution).
    float o_val = 0.0;
    for (uint i = 0u; i < MAX_COLS_PER_THREAD; i++) {
        uint col = col_thread + i * THREADS_PER_ROW;
        if (col >= head_v_dim) break;
        float s = reg_state[i];
        if (col < k_len) {
            s += s_k[col] * d_val;
            o_val += s * s_q[col];
        }
        state[row_base + col] = s;
    }

    o_val += subgroupShuffleXor(o_val, 1u);
    o_val += subgroupShuffleXor(o_val, 2u);
    o_val += subgroupShuffleXor(o_val, 4u);
    o_val += subgroupShuffleXor(o_val, 8u);

    if (col_thread == 0u) {
        out_data[h * head_v_dim + row] = o_val;
    }
}
