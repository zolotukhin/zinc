#version 460
// ZINC — Paged flash attention with grouped-query attention (GQA) support
// RDNA4-optimized: wave64 (64 threads/workgroup), one query head per workgroup
//
// Implements the flash attention algorithm for autoregressive decode:
//   - Single query token attending to the full KV cache
//   - Paged KV cache with 16-token pages accessed via a page table
//   - GQA: multiple query heads share fewer KV heads (n_heads / n_kv_heads)
//   - Online softmax with numerically stable running max/sum
//   - 256-token block chunking for bounded shared memory usage
//
// Dispatch: one workgroup per query head (gl_WorkGroupID.x = head index)

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_EXT_shader_subgroup_extended_types_float16 : enable

layout(local_size_x = 64) in;

layout(push_constant) uniform PushConstants {
    uint head_dim;      // dimension per head (e.g. 128)
    uint n_heads;       // number of query heads
    uint n_kv_heads;    // number of KV heads (n_heads >= n_kv_heads)
    uint seq_len;       // current sequence length (number of cached KV tokens)
    uint page_size;     // tokens per page (16)
    uint attn_scale_bits; // float attention scale (reinterpreted as uint, 0 = use 1/sqrt(head_dim))
    uint sink_offset;     // starting index into sink_data for this layer (layer_idx * n_heads)
};

// Buffer bindings. Q, K, V, and Output are aliased as vec4 so the inner
// dot/V-acc loops can issue 16-byte coherent loads/stores (one wave
// instruction per 4 head_dim elements) instead of 4 scalar ones. All
// head_dim values used in this codebase (128/256/512) are divisible by 4,
// and q_base/k_base/v_base/o_base offsets are multiples of head_dim, so
// the alias is always valid. The Q/K vec4 view feeds Phase 1; the V/O
// vec4 view feeds Phase 4 (V-acc) and Phase 5 (write-out).
layout(set = 0, binding = 0) readonly  buffer Query     { float q_data[];     };
layout(set = 0, binding = 0) readonly  buffer QueryV4   { vec4  q_data_v4[];  };
layout(set = 0, binding = 1) readonly  buffer KCache    { float k_data[];     };
layout(set = 0, binding = 1) readonly  buffer KCacheV4  { vec4  k_data_v4[];  };
layout(set = 0, binding = 2) readonly  buffer VCache    { float v_data[];     };
layout(set = 0, binding = 2) readonly  buffer VCacheV4  { vec4  v_data_v4[];  };
layout(set = 0, binding = 3) readonly  buffer PageTable { uint  page_ids[];   };
layout(set = 0, binding = 4) writeonly buffer Output    { float o_data[];     };
layout(set = 0, binding = 4) writeonly buffer OutputV4  { vec4  o_data_v4[];  };
layout(set = 0, binding = 5) readonly  buffer Sinks     { float sink_data[];  };

// Shared memory for attention block processing
// Attention scores for one 256-token block (max scores held at once)
const uint BLOCK_SIZE = 256u;
shared float s_scores[BLOCK_SIZE];
// Query vector cached in shared memory once per workgroup, packed as vec4
// so Phase 1's dot loop reads aligned 16-byte chunks. 128 vec4 = 512
// floats (same LDS budget as the prior scalar s_q[512]).
shared vec4 s_q4[128];     // supports head_dim up to 512 (Gemma 4 global layers)
// Page-id cache. Phase 4's V-accumulation re-reads page_ids[] once per
// (d, i) pair: 64 threads * (head_dim/64) * block_len lookups per block.
// On head_dim=128 that is 32,768 lookups per WG per block, all to a tiny
// page table that should be cache-resident anyway. Loading once into LDS
// at the top of each block makes the inner loops shared-memory only.
shared uint s_page_ids_block[BLOCK_SIZE];
// Accumulator for output vector, packed as vec4 so Phase 4's V-acc holds
// 4 d-values per thread in one 16-byte LDS slot and Phase 5 writes back
// 16 bytes per coherent store. 128 vec4 = 512 floats (same LDS as the
// prior scalar s_out[512]).
shared vec4 s_out_v4[128]; // supports head_dim up to 512 (Gemma 4 global layers)
// Phase 4 D-split partial buffer. When head_dim_v4 == 32 (head_dim=128),
// only 32 of the 64 wave lanes own a unique d4 in the original formulation.
// The D-split path pairs lanes (tid, tid+32) on the same d4 and splits the
// i-axis between them; the upper-half lanes write their partial here for
// the lower-half lanes to merge before updating s_out_v4. 32 vec4 = 512 B.
shared vec4 s_partial_v4[32];
// Running softmax state
shared float s_max_old;
shared float s_sum_old;
shared float s_reduce[64];
shared float s_reduce_scalar;

void main() {
    uint head = gl_WorkGroupID.x;   // query head index
    uint tid = gl_LocalInvocationID.x;  // 0..63

    // GQA: map query head to its corresponding KV head
    uint kv_head = head / (n_heads / n_kv_heads);

    // Base offset into query buffer for this head
    uint q_base = head * head_dim;

    // --- Load query vector into registers ---
    // Each thread handles one vec4 (4 floats) per stride-64 step. For
    // head_dim=128 (head_dim_v4=32) only threads 0..31 enter the loop,
    // so init covers 32*4 = 128 floats = head_dim. For head_dim=256 all
    // 64 threads do one iter; for head_dim=512 each thread does two
    // iters. The same vec4 layout feeds Phase 4 (V-acc) and Phase 5.
    uint head_dim_v4 = head_dim >> 2;
    uint q_base_v4 = q_base >> 2;
    for (uint d4 = tid; d4 < head_dim_v4; d4 += 64u) {
        s_out_v4[d4] = vec4(0.0);
        s_q4[d4] = q_data_v4[q_base_v4 + d4];
    }

    if (tid == 0u) {
        s_max_old = -1.0e30;
        s_sum_old = 0.0;
    }
    barrier();

    float scale = attn_scale_bits != 0u ? uintBitsToFloat(attn_scale_bits) : inversesqrt(float(head_dim));

    // Total number of pages covering the sequence
    uint total_pages = (seq_len + page_size - 1u) / page_size;

    // --- Process KV cache in 256-token blocks ---
    for (uint block_start = 0u; block_start < seq_len; block_start += BLOCK_SIZE) {
        uint block_end = min(block_start + BLOCK_SIZE, seq_len);
        uint block_len = block_end - block_start;

        // Stage the page_ids[] entries for this block into LDS so both
        // Phase 1 (one lookup per score) and Phase 4 (head_dim/64 *
        // block_len lookups per thread) can read shared memory.
        for (uint i = tid; i < block_len; i += 64u) {
            uint seq_pos = block_start + i;
            s_page_ids_block[i] = page_ids[seq_pos / page_size];
        }
        barrier();

        // --- Phase 1: Compute attention scores for this block ---
        // Each thread computes one or more scores (stride of 64 across block_len).
        // K is read as vec4: each iteration loads 16 bytes per thread and
        // performs one dot(vec4, vec4), so the inner loop runs head_dim/4
        // iterations instead of head_dim. q_base/k_base are head_dim-aligned
        // and head_dim is divisible by 4, so the vec4 alias is valid.
        for (uint i = tid; i < block_len; i += 64u) {
            uint seq_pos = block_start + i;

            // Paged lookup uses the cached page id; offset within page is
            // a cheap modulo of the sequence position.
            uint page_off = seq_pos % page_size;
            uint page_id = s_page_ids_block[i];

            // K cache layout: k_data[page_id * page_size * head_dim * n_kv_heads
            //                         + page_off * head_dim * n_kv_heads
            //                         + kv_head * head_dim + d]
            // Simplified: each page stores page_size tokens, each token stores
            // n_kv_heads * head_dim floats.
            uint k_base_v4 = ((page_id * page_size + page_off) * n_kv_heads * head_dim
                              + kv_head * head_dim) >> 2;

            // Dot product q . k via vec4 chunks.
            float dot_acc = 0.0;
            for (uint d4 = 0u; d4 < head_dim_v4; d4++) {
                dot_acc += dot(s_q4[d4], k_data_v4[k_base_v4 + d4]);
            }

            s_scores[i] = dot_acc * scale;
        }

        barrier();

        // --- Phase 2: Find max score in this block (for numerical stability) ---
        float local_max = -1.0e30;
        for (uint i = tid; i < block_len; i += 64u) {
            local_max = max(local_max, s_scores[i]);
        }
        float block_max = subgroupMax(local_max);
        if (gl_NumSubgroups > 1u) {
            if (gl_SubgroupInvocationID == 0u) {
                s_reduce[gl_SubgroupID] = block_max;
            }
            barrier();
            if (tid == 0u) {
                float merged_max = -1.0e30;
                for (uint sg = 0u; sg < gl_NumSubgroups; sg++) {
                    merged_max = max(merged_max, s_reduce[sg]);
                }
                s_reduce_scalar = merged_max;
            }
            barrier();
            block_max = s_reduce_scalar;
        }

        // New running max across all blocks seen so far
        float new_max = max(s_max_old, block_max);

        // --- Phase 3: Compute exp(score - new_max) and sum ---
        float local_sum = 0.0;
        for (uint i = tid; i < block_len; i += 64u) {
            float e = exp(s_scores[i] - new_max);
            s_scores[i] = e;
            local_sum += e;
        }
        float block_sum = subgroupAdd(local_sum);
        if (gl_NumSubgroups > 1u) {
            if (gl_SubgroupInvocationID == 0u) {
                s_reduce[gl_SubgroupID] = block_sum;
            }
            barrier();
            if (tid == 0u) {
                float merged_sum = 0.0;
                for (uint sg = 0u; sg < gl_NumSubgroups; sg++) {
                    merged_sum += s_reduce[sg];
                }
                s_reduce_scalar = merged_sum;
            }
            barrier();
            block_sum = s_reduce_scalar;
        }

        // --- Phase 4: Rescale previous accumulator + accumulate new V ---
        // V is read as vec4: each thread holds a vec4 acc covering 4
        // contiguous d values, and the inner loop reads one 16-byte
        // V chunk per i instead of one float.
        //
        // For head_dim=128 (head_dim_v4 == 32, Qwen 3 8B) the original
        // d4-strided loop kept only 32 of the 64 wave lanes busy. The
        // D-split path pairs lanes (tid, tid + 32) on the same d4 and
        // splits the i-axis between them, doubling the active lane
        // count and halving the inner-loop iteration count. The hi-half
        // lane writes its partial accumulator into LDS; the lo-half
        // lane merges it and updates s_out_v4.
        //
        // For head_dim_v4 >= 64 (head_dim=256/512) every lane already
        // covers a unique d4, so no split is needed. head_dim_v4 == 16
        // (head_dim=64) is not currently exercised by any model and
        // would need a 4-way split, so it falls through to the original
        // path.
        float rescale = exp(s_max_old - new_max);

        if (head_dim_v4 == 32u) {
            uint d4 = tid & 31u;
            uint i_half = tid >> 5;
            uint half_block = (block_len + 1u) >> 1;
            uint i_lo = i_half * half_block;
            uint i_hi = (i_half == 0u) ? min(half_block, block_len) : block_len;

            // Split the i-loop accumulator into two independent partial
            // accumulators acc0/acc1 and unroll the loop by 2. This breaks
            // the single-accumulator dependency chain on `acc`, letting the
            // wave issue both V loads (and both s_scores[] reads) before
            // either FMA needs to retire — exposing 2-way ILP and helping
            // the compiler hide V-load latency. The math is identical:
            // acc = acc0 + acc1 covers the same i range as the prior single
            // accumulator. Tail handles odd-length i ranges.
            vec4 acc0 = vec4(0.0);
            vec4 acc1 = vec4(0.0);
            uint i = i_lo;
            for (; i + 2u <= i_hi; i += 2u) {
                uint seq_pos_0 = block_start + i;
                uint seq_pos_1 = seq_pos_0 + 1u;
                uint page_off_0 = seq_pos_0 % page_size;
                uint page_off_1 = seq_pos_1 % page_size;
                uint page_id_0 = s_page_ids_block[i];
                uint page_id_1 = s_page_ids_block[i + 1u];

                uint v_base_v4_0 = ((page_id_0 * page_size + page_off_0) * n_kv_heads * head_dim
                                    + kv_head * head_dim) >> 2;
                uint v_base_v4_1 = ((page_id_1 * page_size + page_off_1) * n_kv_heads * head_dim
                                    + kv_head * head_dim) >> 2;

                acc0 += s_scores[i] * v_data_v4[v_base_v4_0 + d4];
                acc1 += s_scores[i + 1u] * v_data_v4[v_base_v4_1 + d4];
            }
            // Tail: handle the final i if (i_hi - i_lo) is odd.
            for (; i < i_hi; i++) {
                uint seq_pos = block_start + i;
                uint page_off = seq_pos % page_size;
                uint page_id = s_page_ids_block[i];

                uint v_base_v4 = ((page_id * page_size + page_off) * n_kv_heads * head_dim
                                  + kv_head * head_dim) >> 2;

                acc0 += s_scores[i] * v_data_v4[v_base_v4 + d4];
            }
            vec4 acc = acc0 + acc1;

            if (i_half == 1u) {
                s_partial_v4[d4] = acc;
            }
            barrier();
            if (i_half == 0u) {
                s_out_v4[d4] = s_out_v4[d4] * rescale + acc + s_partial_v4[d4];
            }
        } else {
            for (uint d4 = tid; d4 < head_dim_v4; d4 += 64u) {
                vec4 acc = vec4(0.0);
                for (uint i = 0u; i < block_len; i++) {
                    uint seq_pos = block_start + i;
                    uint page_off = seq_pos % page_size;
                    uint page_id = s_page_ids_block[i];

                    uint v_base_v4 = ((page_id * page_size + page_off) * n_kv_heads * head_dim
                                      + kv_head * head_dim) >> 2;

                    acc += s_scores[i] * v_data_v4[v_base_v4 + d4];
                }
                s_out_v4[d4] = s_out_v4[d4] * rescale + acc;
            }
        }

        barrier();

        // Update running softmax state
        if (tid == 0u) {
            s_sum_old = s_sum_old * rescale + block_sum;
            s_max_old = new_max;
        }
        barrier();
    }

    // --- Phase 5: Normalize output by total softmax sum ---
    float final_sum = s_sum_old;
    float rescale = 1.0;
    float sink_val = sink_data[sink_offset + head];
    if (!isnan(sink_val)) {
        float sink_max = max(s_max_old, sink_val);
        rescale = s_sum_old > 0.0 ? exp(s_max_old - sink_max) : 0.0;
        final_sum = s_sum_old * rescale + exp(sink_val - sink_max);
    }

    float inv_sum = final_sum > 0.0 ? 1.0 / final_sum : 0.0;
    uint o_base_v4 = (head * head_dim) >> 2;

    for (uint d4 = tid; d4 < head_dim_v4; d4 += 64u) {
        o_data_v4[o_base_v4 + d4] = s_out_v4[d4] * rescale * inv_sum;
    }
}
