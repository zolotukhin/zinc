#version 460
// ZINC — Q4_K MoE DMMV batched across N prompt tokens.
//
// Cross-token-batched analogue of dmmv_q4k_moe_kpar.comp. Each workgroup
// handles one (row_pair, expert_slot, token_idx) triple, reads the
// per-token input vector and the (token, expert_slot) routed expert's
// weight slice, and writes into a [n_tokens × n_experts_used × M]
// output tensor. Saves N× the per-token dispatch + setup overhead vs
// the per-token MoE path that prefillBatched currently falls back to
// for qwen35moe / qwen36moe.
//
// Dispatch: ((M+1)/2, n_experts_used, n_tokens). Local size = 64.
//
// Bindings:
//   0  W_stacked  (Q4_K, all n_experts × M × K)
//   1  X_batch    (f32 vec4, [n_tokens × K])
//   2  Y_batch    (f32, [n_tokens × n_experts_used × M])
//   3  Routing    (u32 [n_tokens × n_experts_used] — flattened per-token expert IDs)
//
// Push constants:
//   M               : output rows per expert
//   K               : hidden_dim
//   expert_stride   : bytes per expert in the stacked weight tensor
//   n_experts_used  : top-k size (8 for qwen35moe / qwen36moe)
//   x_token_stride  : elements per token in X_batch (= K)
//   y_token_stride  : elements per token in Y_batch (= n_experts_used × M)

#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64) in;

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;
    uint expert_stride;
    uint n_experts_used;
    uint x_token_stride;
    uint y_token_stride;
};

layout(set = 0, binding = 0) readonly  buffer MatrixA   { uint a_u32[]; };
layout(set = 0, binding = 1) readonly  buffer VectorX   { vec4 x_v4[]; };
layout(set = 0, binding = 2) writeonly buffer VectorY   { float y_data[]; };
layout(set = 0, binding = 3) readonly  buffer MoeRouting { uint routing_data[]; };

const uint NUM_ROWS = 2u;
const uint Q4K_BLOCK_U32 = 36u;

vec4 unpack_nibbles_lo(uint v) {
    return vec4(float(v & 0xFu), float((v >> 8) & 0xFu),
                float((v >> 16) & 0xFu), float((v >> 24) & 0xFu));
}
vec4 unpack_nibbles_hi(uint v) {
    return vec4(float((v >> 4) & 0xFu), float((v >> 12) & 0xFu),
                float((v >> 20) & 0xFu), float((v >> 28) & 0xFu));
}

void decode_sb(uint bytes[12], uint sb, out float sc, out float mn) {
    if (sb < 4u) {
        sc = float(bytes[sb] & 63u);
        mn = float(bytes[sb + 4u] & 63u);
    } else {
        sc = float((bytes[sb + 4u] & 0xFu) | ((bytes[sb - 4u] >> 6) << 4));
        mn = float(((bytes[sb + 4u] >> 4) & 0xFu) | ((bytes[sb] >> 6) << 4));
    }
}

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint wg_id_x = gl_WorkGroupID.x;
    uint expert_slot = gl_WorkGroupID.y;
    uint token_idx = gl_WorkGroupID.z;

    // Per-(token, expert_slot) routed expert id.
    uint expert_id = routing_data[token_idx * n_experts_used + expert_slot];
    uint a_offset_bytes = expert_id * expert_stride;

    const uint THREADS_PER_BLOCK = 16u;
    const uint it_size = 64u / THREADS_PER_BLOCK;
    uint itid = tid % THREADS_PER_BLOCK;
    uint ix = tid / THREADS_PER_BLOCK;

    uint il = itid / 4u;
    uint ir = itid % 4u;
    uint v_im = il / 2u;
    uint v_in = il % 2u;
    uint l0 = 4u * (2u * ir + v_in);
    uint q_offset_in_half = 32u * v_im + l0;
    uint y_offset_local = 64u * v_im + l0;

    uint x_base_v4 = (token_idx * x_token_stride) / 4u;
    uint a_base_u32 = a_offset_bytes / 4u;
    uint blocks_per_row = K / 256u;

    uint y_base = token_idx * y_token_stride + expert_slot * M;

    uint sb_a = 2u * v_im;
    uint sb_b = 2u * v_im + 1u;
    uint sb_c = 2u * v_im + 4u;
    uint sb_d = 2u * v_im + 5u;

    for (uint r = 0u; r < NUM_ROWS; r++) {
        uint row = wg_id_x * NUM_ROWS + r;
        if (row >= M) break;

        uint row_u32 = a_base_u32 + row * blocks_per_row * Q4K_BLOCK_U32;
        float sum = 0.0;

        for (uint i = ix; i < blocks_per_row; i += it_size) {
            uint blk_u32 = row_u32 + i * Q4K_BLOCK_U32;

            uint d_dmin = a_u32[blk_u32];
            float d_val = unpackHalf2x16(d_dmin & 0xFFFFu).x;
            float dmin_val = unpackHalf2x16(d_dmin >> 16).x;

            uint sc0 = a_u32[blk_u32 + 1u];
            uint sc1 = a_u32[blk_u32 + 2u];
            uint sc2 = a_u32[blk_u32 + 3u];

            uint qs_u32_0 = a_u32[blk_u32 + 4u + q_offset_in_half / 4u];
            uint qs_u32_1 = a_u32[blk_u32 + 4u + q_offset_in_half / 4u + 16u];

            vec4 q0_lo = unpack_nibbles_lo(qs_u32_0);
            vec4 q0_hi = unpack_nibbles_hi(qs_u32_0);
            vec4 q1_lo = unpack_nibbles_lo(qs_u32_1);
            vec4 q1_hi = unpack_nibbles_hi(qs_u32_1);

            uint b_idx = (i * 256u + y_offset_local) / 4u;
            vec4 by0 = x_v4[x_base_v4 + b_idx];
            vec4 by1 = x_v4[x_base_v4 + b_idx + 8u];
            uint b_idx2 = (i * 256u + y_offset_local + 128u) / 4u;
            vec4 by2 = x_v4[x_base_v4 + b_idx2];
            vec4 by3 = x_v4[x_base_v4 + b_idx2 + 8u];

            uint bytes[12];
            bytes[0] = sc0 & 0xFFu; bytes[1] = (sc0>>8)&0xFFu; bytes[2] = (sc0>>16)&0xFFu; bytes[3] = (sc0>>24)&0xFFu;
            bytes[4] = sc1 & 0xFFu; bytes[5] = (sc1>>8)&0xFFu; bytes[6] = (sc1>>16)&0xFFu; bytes[7] = (sc1>>24)&0xFFu;
            bytes[8] = sc2 & 0xFFu; bytes[9] = (sc2>>8)&0xFFu; bytes[10] = (sc2>>16)&0xFFu; bytes[11] = (sc2>>24)&0xFFu;

            float sc_a, mn_a, sc_b, mn_b, sc_c, mn_c, sc_d, mn_d;
            decode_sb(bytes, sb_a, sc_a, mn_a);
            decode_sb(bytes, sb_b, sc_b, mn_b);
            decode_sb(bytes, sb_c, sc_c, mn_c);
            decode_sb(bytes, sb_d, sc_d, mn_d);

            float f0 = d_val * sc_a, b0 = dmin_val * mn_a;
            float f1 = d_val * sc_b, b1 = dmin_val * mn_b;
            float f2 = d_val * sc_c, b2 = dmin_val * mn_c;
            float f3 = d_val * sc_d, b3 = dmin_val * mn_d;

            sum += dot(vec4(f0) * q0_lo - vec4(b0), by0);
            sum += dot(vec4(f1) * q0_hi - vec4(b1), by1);
            sum += dot(vec4(f2) * q1_lo - vec4(b2), by2);
            sum += dot(vec4(f3) * q1_hi - vec4(b3), by3);
        }

        sum = subgroupAdd(sum);
        if (tid == 0u) {
            y_data[y_base + row] = sum;
        }
    }
}
